feg:TransversePlane a owl:NamedIndividual,
        feg:PlaneOfMotion ;
    rdfs:label "Transverse Plane" ;
    rdfs:comment "The anatomical plane that divides the body into superior and inferior portions. Movements occurring primarily in this plane are typically rotational or horizontal in orientation. Examples include Russian twists, cable wood chops, rotational medicine ball throws, and hip internal or external rotation." ;
    skos:inScheme feg:PlaneOfMotionScheme .

feg:TrapBar a owl:NamedIndividual,
        feg:Equipment ;
    rdfs:label "Trap Bar" ;
    rdfs:comment "A hexagonal or diamond-shaped bar that allows the lifter to stand inside it, used for deadlifts and shrugs." ;
    skos:altLabel "Hex Bar" .

feg:TricepsLateralHead a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Triceps Lateral Head" ;
