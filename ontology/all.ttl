    rdfs:label "Triceps Medial Head" ;
    skos:broader feg:TricepsBrachii ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Triceps Medial Head" .

feg:Unilateral a owl:NamedIndividual,
        feg:Laterality ;
    rdfs:label "Unilateral" ;
    rdfs:comment "One limb works at a time, independently of the other. Examples: single-leg squat, single-arm dumbbell row, single-leg Romanian deadlift." ;
    skos:inScheme feg:LateralityScheme .

feg:UpperTrapezius a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Upper Trapezius" ;
    skos:altLabel "Upper Traps" ;
    skos:broader feg:Trapezius ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Upper Trapezius" .

feg:VastusIntermedius a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Vastus Intermedius" ;
    skos:broader feg:Quadriceps ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Vastus Intermedius" .

feg:VastusLateralis a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Vastus Lateralis" ;
    skos:broader feg:Quadriceps ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Vastus Lateralis" .

feg:VastusMedialis a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Vastus Medialis" ;
    skos:altLabel "VMO" ;
    skos:broader feg:Quadriceps ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Vastus Medialis" .

feg:VerticalPull a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:label "Vertical Pull" ;
    rdfs:comment "Movements in which force is produced by pulling vertically toward the body, principally targeting the lats and biceps." ;
    skos:broader feg:Pull ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Vertical Pull" .

feg:VerticalPush a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:label "Vertical Push" ;
    rdfs:comment "Movements in which force is produced by pushing vertically away from the body, principally targeting the shoulders and triceps." ;
    skos:broader feg:Push ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Vertical Push" .

feg:WallBall a owl:NamedIndividual,
        feg:Equipment ;
    rdfs:label "Wall Ball" ;
    rdfs:comment "A large, soft medicine ball thrown against a wall for squat-to-throw conditioning exercises." .

feg:WeightPlate a owl:NamedIndividual,
        feg:Equipment ;
    rdfs:label "Weight Plate" ;
    rdfs:comment "A standard barbell weight plate used as a standalone implement for overhead, carry, and rotational exercises." ;
    skos:altLabel "Plate" .

feg:WristExtension a owl:NamedIndividual,
        skos:Concept,
        feg:JointAction ;
    rdfs:label "Wrist Extension" ;
    rdfs:comment "Bending the hand toward the back of the forearm. Primary drivers: wrist extensors (extensor carpi radialis, extensor carpi ulnaris)." ;
    skos:broader feg:Wrist ;
    skos:inScheme feg:JointActionScheme ;
    skos:prefLabel "Wrist Extension" .

feg:WristFlexion a owl:NamedIndividual,
        skos:Concept,
        feg:JointAction ;
    rdfs:label "Wrist Flexion" ;
    rdfs:comment "Bending the hand toward the front of the forearm. Primary drivers: wrist flexors (flexor carpi radialis, flexor carpi ulnaris)." ;
    skos:broader feg:Wrist ;
    skos:inScheme feg:JointActionScheme ;
    skos:prefLabel "Wrist Flexion" .

feg:catalog a owl:Ontology ;
    rdfs:label "Free Exercise Graph — Source Catalog" ;
    rdfs:comment "DCAT Dataset individuals representing upstream data sources ingested into the graph." ;
    owl:versionInfo "1.0.0" .

feg:Locomotion a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:label "Locomotion" ;
    rdfs:comment "Movements involving whole-body travel through space, including running, jumping, and crawling patterns." ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Locomotion" .

feg:PassiveTarget a owl:NamedIndividual,
        feg:InvolvementDegree ;
    rdfs:label "Passive Target" ;
    rdfs:comment "A muscle that is the passive target of a stretch or soft tissue technique. Used in Mobility and SoftTissue exercises where the muscle is being lengthened or treated rather than actively contracting. Exercises with at least one PassiveTarget involvement are exempt from the PrimeMover requirement. Synergists and Stabilizers may still be present if other muscles are actively engaged." .

feg:PrimeMover a owl:NamedIndividual,
        feg:InvolvementDegree ;
    rdfs:label "Prime Mover" ;
    rdfs:comment "The muscle whose primary biomechanical action directly produces the exercise's defining joint action(s). The prime mover is the intended training target — the muscle the exercise is designed to develop. A muscle that is active but contributes via a secondary action should be Synergist instead. Example: LateralDeltoid's primary action is shoulder abduction; it should not be PrimeMover on a pressing or throwing exercise where ShoulderFlexion is the defining action. When multiple muscles share the same primary joint action (e.g. all four quadriceps heads all producing KneeExtension), all may be PrimeMover — they will be consolidated into the parent group post-ingestion by repair_04. Exception for explosive hip extension movements (cleans, snatches, jumps): GluteusMaximus is the primary PrimeMover. Hamstrings contribute to hip extension but are biarticular and are better classified Synergist in these movements." .

feg:Psoas a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Psoas" ;
    skos:broader feg:HipFlexors ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Psoas" .

feg:Stabilizer a owl:NamedIndividual,
        feg:InvolvementDegree ;
    rdfs:label "Stabilizer" ;
    rdfs:comment "A muscle that contracts to stabilize a joint during the exercise without contributing directly to the movement. Stabilizers are active but not trained in a meaningful hypertrophic or strength sense by the exercise." .

feg:Synergist a owl:NamedIndividual,
        feg:InvolvementDegree ;
    rdfs:label "Synergist" ;
    rdfs:comment "A muscle that assists the prime mover in producing the movement. The synergist contributes meaningfully to the exercise but is not the primary target." .

feg:Traps a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Traps" ;
    skos:altLabel "Trapezius" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Traps" ;
    skos:topConceptOf feg:MuscleScheme .

feg:equipment a owl:ObjectProperty ;
    rdfs:label "equipment" ;
    rdfs:comment "Relates an exercise to the equipment used to perform it." ;
    rdfs:domain feg:Exercise ;
    rdfs:range feg:Equipment .

feg:exerciseStyle a owl:ObjectProperty ;
    rdfs:label "exercise style" ;
    rdfs:comment "The training system, tradition, or methodological context the exercise belongs to. Assign only when the exercise has a clear home in a named tradition (e.g. a Turkish Get-Up is unambiguously Grinds/kettlebell; a barbell back squat is not exclusively Powerlifting). Do not assign when the exercise is generic. Multiple styles permitted where genuinely appropriate." ;
    rdfs:domain feg:Exercise ;
    rdfs:range feg:ExerciseStyle .

feg:hasInvolvement a owl:ObjectProperty ;
    rdfs:label "has involvement" ;
    rdfs:comment "Relates an exercise to a muscle involvement instance describing a muscle recruited during its execution." ;
    rdfs:domain feg:Exercise ;
    rdfs:range feg:MuscleInvolvement .

feg:isCombination a owl:DatatypeProperty ;
    rdfs:label "is combination" ;
    rdfs:comment "Set to true when the exercise is a deliberate sequence of two independent movements performed as one (e.g. squat-to-press, deadlift-to-row, lunge-to-curl). Distinct from feg:isCompound, which refers to joint mechanics. A combination exercise is always compound, but a compound exercise is not necessarily a combination. Omit or set to false for single-movement exercises." ;
    rdfs:domain feg:Exercise ;
    rdfs:range xsd:boolean .

feg:isCompound a owl:DatatypeProperty ;
    rdfs:label "is compound" ;
    rdfs:comment "Set to true when the exercise involves meaningful force production across multiple joints (e.g. squat, deadlift, bench press, row). Omit or set to false for single-joint isolation exercises (e.g. bicep curl, leg extension, lateral raise). When in doubt, count primary joint actions: two or more distinct joints contributing to force production indicates compound." ;
    rdfs:domain feg:Exercise ;
    rdfs:range xsd:boolean .

feg:isUnilateral a owl:DatatypeProperty ;
    rdfs:label "is unilateral" ;
    rdfs:comment "DEPRECATED — replaced by feg:laterality (ADR-075). This property cannot distinguish Contralateral and Ipsilateral exercises from plain Unilateral. Use feg:laterality with feg:Bilateral, feg:Unilateral, feg:Contralateral, or feg:Ipsilateral instead. Will be removed in a subsequent MAJOR version bump after re-enrichment." ;
    rdfs:domain feg:Exercise ;
    rdfs:range xsd:boolean ;
    owl:deprecated true .

feg:laterality a owl:ObjectProperty ;
    rdfs:label "laterality" ;
    rdfs:comment "Describes how limb involvement is distributed across the left and right sides of the body. Use feg:Bilateral for symmetric two-limb exercises. Use feg:Unilateral for exercises performed one limb at a time. Use feg:Contralateral when opposite limbs work together (e.g. bird dog, dead bug). Use feg:Ipsilateral when same-side limbs work together. Replaces the deprecated feg:isUnilateral boolean (ADR-075)." ;
    rdfs:domain feg:Exercise ;
    rdfs:range feg:Laterality .

feg:legacySourceId a owl:DatatypeProperty ;
    rdfs:label "legacy source ID" ;
    rdfs:comment "The original identifier for this exercise in its upstream source dataset. Preserved for provenance and upstream traceability. Use dcterms:source to identify which dataset this ID belongs to." ;
    rdfs:domain feg:Exercise ;
    rdfs:range xsd:string .

feg:movementPattern a owl:ObjectProperty ;
    rdfs:label "movement pattern" ;
    rdfs:comment "Use the most specific pattern that applies — prefer child patterns over parent patterns (e.g. Squat over KneeDominant, HorizontalPush over Push). Use a parent only when no child fits. Compound exercises may have more than one pattern. If no pattern fits well, return an empty array — do not force an ill-fitting label. Isolation exercises that are not curls, rows, presses, or hinges often have no clean pattern. Push and Pull patterns require multi-joint force production. Single-joint isolation movements (bicep curls, lateral raises, triceps extensions, leg extensions/curls) have no movement pattern — return empty array. Do not assign Pull to curls or Push to raises." ;
    rdfs:domain feg:Exercise ;
    rdfs:range feg:MovementPattern .

feg:muscle a owl:ObjectProperty ;
    rdfs:label "muscle" ;
    rdfs:comment "Prefer the most specific term available: MuscleHead > MuscleGroup > MuscleRegion. Use a region term only if no group applies; use a group term only if no head applies. Exception: groups marked useGroupLevel=true are the correct term — do not descend to their heads. Exception: Core (a MuscleGroup under Abdominals) is a convenience term permitted on compound movements where abdominal bracing is incidental; it must always be assigned as Stabilizer. Critical: joint action concept names (e.g. ScapularUpwardRotation, HipFlexion, ElbowFlexion, ScapularRetraction) are NOT muscle names — never use a joint action concept as a muscle value. TricepsBrachii (group) must not be used — always decompose into TricepsLongHead, TricepsLateralHead, and TricepsMedialHead, including for Stabilizer and Synergist roles; TricepsLongHead is meaningfully distinct as it crosses the shoulder joint. On Mobility exercises and passive stretches, minimise Stabilizers — include one only when there is a clear active stabilisation demand; do not routinely add Core or RotatorCuff. A muscle may not appear more than once across an exercise's involvements — if the same muscle would be assigned at two different degrees, use the higher-priority degree only (PrimeMover > Synergist > Stabilizer). An exercise may not list both a muscle and any of its SKOS ancestors — this double-counts the same muscle mass; use the most specific term only." ;
    rdfs:domain feg:MuscleInvolvement ;
    rdfs:range feg:Muscle .

feg:planeOfMotion a owl:ObjectProperty ;
    rdfs:label "plane of motion" ;
    rdfs:comment "The cardinal plane(s) in which the primary movement of the exercise occurs. An exercise may involve multiple planes. Use feg:SagittalPlane for forward/backward movement, feg:FrontalPlane for side-to-side movement, feg:TransversePlane for rotational movement." ;
    rdfs:domain feg:Exercise ;
    rdfs:range feg:PlaneOfMotion .

feg:primaryJointAction a owl:ObjectProperty ;
    rdfs:label "primary joint action" ;
    rdfs:comment "Assign the joint actions that directly produce the exercise's defining movement — the mechanical reason the exercise exists. For a deadlift: HipExtension, KneeExtension. For a curl: ElbowFlexion. Typically 1–3 per exercise. Leaf-level concepts only — do not assign joint grouping nodes (Shoulder, Hip, etc.). Anti-movement rule: if the exercise is AntiExtension → SpinalStability; AntiRotation → SpinalStability; AntiLateralFlexion → SpinalStability. In all three cases the spine is isometrically resisting — not producing — movement. Do NOT assign SpinalExtension, SpinalRotation, or SpinalLateralFlexion to these exercises." ;
    rdfs:domain feg:Exercise ;
    rdfs:range feg:JointAction ;
    rdfs:subPropertyOf feg:jointAction .

feg:supportingJointAction a owl:ObjectProperty ;
    rdfs:label "supporting joint action" ;
    rdfs:comment "Assign joint actions that contribute meaningfully but are not the defining stimulus — only those relevant for substitution decisions, fatigue accumulation, or inter-muscular coordination. This is not a biomechanical inventory: omit incidental or purely stabilising actions. Leave empty if nothing qualifies. Typically 0–3 per exercise. Leaf-level concepts only. Setup-position rule: do not assign joint actions that describe the starting position of the exercise — only actions that occur during the movement itself. Examples: bent knees at the start of a glute bridge are setup, not KneeFlexion as a joint action; semi-locked knees during a good morning are setup, not a movement action. Ankle mechanics for sagittal plane lifts: for squats, deadlifts, and lunges the relevant ankle action is Dorsiflexion (the ankle dorsiflexes to allow depth). AnkleEversion and AnkleInversion are movement faults, not defining supporting actions in these exercises." ;
    rdfs:domain feg:Exercise ;
    rdfs:range feg:JointAction ;
    rdfs:subPropertyOf feg:jointAction .

feg:trainingModality a owl:ObjectProperty ;
    rdfs:label "training modality" ;
    rdfs:comment "Assign only when the modality is a defining characteristic of the exercise, not merely its typical training context. Plyometrics: explosive intent is the defining feature. Mobility: flexibility or range of motion is the defining feature. Cardio: cardiovascular adaptation is the defining feature. Omit for most resistance training exercises — a barbell squat, bench press, or deadlift has no defining modality." ;
    rdfs:domain feg:Exercise ;
    rdfs:range feg:TrainingModality .

feg:useGroupLevel a owl:DatatypeProperty ;
    rdfs:label "use group level" ;
    rdfs:comment "Indicates that this MuscleGroup functions as a single training unit — its constituent muscles cannot be selectively recruited or meaningfully targeted independently through exercise selection. The group term is the appropriate level of specificity; the individual head-level concepts exist for anatomical completeness but do not represent distinct training outcomes." ;
    rdfs:domain feg:MuscleGroup ;
    rdfs:range xsd:boolean ;
    skos:editorialNote "Used by the classification pipeline to enforce group-level usage. Groups with this flag are surfaced in the prompt as explicit exceptions to the head-preference rule, and a SHACL constraint rejects any classification that references one of their child heads." .

feg:BicepsBrachii a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Biceps Brachii" ;
    skos:broader feg:Biceps ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Biceps Brachii" .

feg:Calves a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Calves" ;
    skos:broader feg:LowerLeg ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Calves" .

feg:Elbow a skos:Concept ;
    rdfs:label "Elbow" ;
    rdfs:comment "Grouping node for elbow joint actions." ;
    skos:inScheme feg:JointActionScheme ;
    skos:prefLabel "Elbow" .

feg:Forearm a skos:Concept ;
    rdfs:label "Forearm" ;
    rdfs:comment "Grouping node for radioulnar joint actions." ;
    skos:inScheme feg:JointActionScheme ;
    skos:prefLabel "Forearm" .

feg:Gastrocnemius a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Gastrocnemius" ;
    skos:broader feg:Calves ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Gastrocnemius" ;
    feg:useGroupLevel true .

feg:Knee a skos:Concept ;
    rdfs:label "Knee" ;
    rdfs:comment "Grouping node for knee joint actions." ;
    skos:inScheme feg:JointActionScheme ;
    skos:prefLabel "Knee" .

feg:Lats a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Lats" ;
    skos:altLabel "Latissimus Dorsi" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Lats" ;
    skos:topConceptOf feg:MuscleScheme .

feg:LowerBack a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Lower Back" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Lower Back" ;
    skos:topConceptOf feg:MuscleScheme .

feg:MiddleBack a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Middle Back" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Middle Back" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Obliques a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Obliques" ;
    skos:broader feg:Abdominals ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Obliques" ;
    feg:useGroupLevel true .

feg:PectoralisMajor a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Pectoralis Major" ;
    skos:altLabel "Pec Major" ;
    skos:broader feg:Chest ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Pectoralis Major" .

feg:Peroneals a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Peroneals" ;
    rdfs:comment "Lateral compartment of the lower leg. Responsible for ankle eversion and assist plantarflexion." ;
    skos:altLabel "Fibularis" ;
    skos:broader feg:LowerLeg ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Peroneals" .

feg:Pull a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:label "Pull" ;
    rdfs:comment "Movements in which force is produced by pulling load toward the body." ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Pull" .

feg:Push a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:label "Push" ;
    rdfs:comment "Movements in which force is produced by pushing load away from the body." ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Push" .

feg:Rhomboids a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Rhomboids" ;
    skos:broader feg:MiddleBack ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Rhomboids" ;
    feg:useGroupLevel true .

feg:Shins a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Shins" ;
    rdfs:comment "Colloquial term for the anterior lower leg compartment. Contains the muscles responsible for ankle dorsiflexion and toe extension." ;
    skos:broader feg:LowerLeg ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Shins" .

feg:Shoulders a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Shoulders" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Shoulders" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Triceps a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Triceps" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Triceps" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Wrist a skos:Concept ;
    rdfs:label "Wrist" ;
    rdfs:comment "Grouping node for radiocarpal joint actions." ;
    skos:inScheme feg:JointActionScheme ;
    skos:prefLabel "Wrist" .

feg:WristExtensors a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Wrist Extensors" ;
    skos:broader feg:Forearms ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Wrist Extensors" ;
    feg:useGroupLevel true .

feg:WristFlexors a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Wrist Flexors" ;
    skos:broader feg:Forearms ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Wrist Flexors" ;
    feg:useGroupLevel true .

feg:degree a owl:ObjectProperty ;
    rdfs:label "degree" ;
    rdfs:comment "PrimeMover: the muscle directly produces the exercise's defining movement. Synergist: assists or fine-tunes the prime mover. Stabilizer: isometrically holds a joint or segment — does not contribute to the primary movement. PassiveTarget: tissue being lengthened or mobilised — Mobility and SoftTissue exercises only. Every exercise must have at least one PrimeMover, or at least one PassiveTarget for Mobility and SoftTissue exercises. Core must always be assigned as Stabilizer — for dedicated core exercises where the abdominals are the primary target, use specific muscles (RectusAbdominis, Obliques, TransverseAbdominis) instead." ;
    rdfs:domain feg:MuscleInvolvement ;
    rdfs:range feg:InvolvementDegree .

feg:jointAction a owl:ObjectProperty ;
    rdfs:label "joint action" ;
    rdfs:comment "Umbrella property relating an exercise to its mechanical joint actions. In data, use feg:primaryJointAction or feg:supportingJointAction rather than this property directly. Queries over feg:jointAction will match both subproperties when RDFS inference is active." ;
    rdfs:domain feg:Exercise ;
    rdfs:range feg:JointAction .

feg:Abductors a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Abductors" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Abductors" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Biceps a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Biceps" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Biceps" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Chest a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Chest" ;
    skos:altLabel "Pectorals" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Chest" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Deltoid a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Deltoid" ;
    skos:broader feg:Shoulders ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Deltoid" .

feg:ErectorSpinae a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Erector Spinae" ;
    skos:broader feg:LowerBack ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Erector Spinae" ;
    feg:useGroupLevel true .

feg:Forearms a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Forearms" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Forearms" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Hamstrings a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Hamstrings" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Hamstrings" ;
    skos:topConceptOf feg:MuscleScheme .

feg:KneeDominant a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:label "Knee Dominant" ;
    rdfs:comment "Movements in which the knee is the primary joint driving the exercise, involving significant quadriceps recruitment." ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Knee Dominant" .

feg:Neck a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Neck" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Neck" ;
    skos:topConceptOf feg:MuscleScheme .

feg:PlaneOfMotionScheme a skos:ConceptScheme ;
    rdfs:label "Planes of Motion" ;
    rdfs:comment "A concept scheme representing the three standard anatomical planes used to describe the primary directional orientation of human movement: Sagittal, Frontal, and Transverse." .

feg:Scalenes a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Scalenes" ;
    skos:broader feg:Neck ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Scalenes" ;
    feg:useGroupLevel true .

feg:Trapezius a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Trapezius" ;
    skos:broader feg:Traps ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Trapezius" .

feg:TricepsBrachii a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Triceps Brachii" ;
    skos:broader feg:Triceps ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Triceps Brachii" .

feg:Abdominals a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Abdominals" ;
    skos:altLabel "Abs" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Abdominals" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Adductors a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Adductors" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Adductors" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Ankle a skos:Concept ;
    rdfs:label "Ankle" ;
    rdfs:comment "Grouping node for ankle joint actions." ;
    skos:inScheme feg:JointActionScheme ;
    skos:prefLabel "Ankle" .

feg:Glutes a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Glutes" ;
    skos:altLabel "Gluteal Muscles" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Glutes" ;
    skos:topConceptOf feg:MuscleScheme .

feg:HipFlexors a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Hip Flexors" ;
    skos:altLabel "HipFlexors" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Hip Flexors" ;
    skos:scopeNote "Use only when both Psoas (Iliopsoas) and Sartorius are involved. If only one branch is active, use the specific child instead." ;
    skos:topConceptOf feg:MuscleScheme .

feg:LateralityScheme a skos:ConceptScheme ;
    rdfs:label "Laterality" ;
    rdfs:comment "Describes how limb involvement is distributed across the left and right sides of the body during an exercise." .

feg:Quadriceps a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Quadriceps" ;
    skos:altLabel "Quads" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Quadriceps" ;
    skos:topConceptOf feg:MuscleScheme .

feg:RotatorCuff a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Rotator Cuff" ;
    skos:broader feg:Shoulders ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Rotator Cuff" ;
    feg:useGroupLevel true .

feg:Muscle a owl:Class ;
    rdfs:label "Muscle" ;
    rdfs:comment "Superclass for all muscle vocabulary terms. Covers regions, groups, and heads. The feg:muscle property on MuscleInvolvement may point to any level of the hierarchy." ;
    owl:disjointWith feg:JointAction .

feg:MuscleInvolvement a owl:Class ;
    rdfs:label "Muscle Involvement" ;
    rdfs:comment "A relationship between a specific exercise and a specific muscle, capturing the degree to which that muscle is recruited during the exercise. A single exercise may have multiple muscle involvements, one per involved muscle." .

feg:PlaneOfMotion a owl:Class ;
    rdfs:label "Plane of Motion" ;
    rdfs:comment "A standard anatomical reference plane used to characterize the directional pattern in which a movement primarily occurs. The canonical instances are Sagittal, Frontal, and Transverse." .

feg:Spine a skos:Concept ;
    rdfs:label "Spine" ;
    rdfs:comment "Grouping node for spinal joint actions. Covers lumbar and thoracic segments together unless a distinction is clinically significant for exercise classification." ;
    skos:inScheme feg:JointActionScheme ;
    skos:prefLabel "Spine" .

feg:TrunkStability a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:label "Trunk Stability" ;
    rdfs:comment "Movements that train the trunk to resist external forces rather than produce movement. Parent concept — prefer the more specific anti-movement sub-patterns where applicable." ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Trunk Stability" .

feg:InvolvementDegree a owl:Class ;
    rdfs:label "Involvement Degree" ;
    rdfs:comment "A classification describing the role a muscle plays in an exercise." .

feg:Laterality a owl:Class ;
    rdfs:label "Laterality" ;
    rdfs:comment "Describes how limb involvement is distributed across the left and right sides of the body. Four values: Bilateral, Unilateral, Contralateral, Ipsilateral. See laterality.ttl for named individuals." .

feg:Scapula a skos:Concept ;
    rdfs:label "Scapula" ;
    rdfs:comment "Grouping node for scapulothoracic joint actions." ;
    skos:inScheme feg:JointActionScheme ;
    skos:prefLabel "Scapula" .

feg:LowerLeg a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Lower Leg" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Lower Leg" ;
    skos:topConceptOf feg:MuscleScheme .

feg:TrainingModality a owl:Class ;
    rdfs:label "Training Modality" ;
    rdfs:comment "A category describing the physiological adaptation targeted by an exercise or program. Examples include strength, hypertrophy, cardio, and mobility." .

feg:ExerciseStyleScheme a skos:ConceptScheme ;
    rdfs:label "Exercise Style" ;
    rdfs:comment "The training system, tradition, or methodological context an exercise belongs to. Distinct from training modality (which describes physiological adaptation). An exercise style describes where the exercise comes from — its community, technique standards, and cultural context." .

feg:Hip a skos:Concept ;
    rdfs:label "Hip" ;
    rdfs:comment "Grouping node for hip joint actions." ;
    skos:inScheme feg:JointActionScheme ;
    skos:prefLabel "Hip" .

feg:Shoulder a skos:Concept ;
    rdfs:label "Shoulder" ;
    rdfs:comment "Grouping node for glenohumeral joint actions." ;
    skos:inScheme feg:JointActionScheme ;
    skos:prefLabel "Shoulder" .

feg:ExerciseStyle a owl:Class ;
    rdfs:label "Exercise Style" ;
    rdfs:comment "The training system, tradition, or methodological context an exercise belongs to. Distinct from feg:TrainingModality, which describes physiological adaptation. See exercise_styles.ttl for named individuals." .

feg:Exercise a owl:Class ;
    rdfs:label "Exercise" ;
    rdfs:comment "A bodily activity that enhances or maintains physical fitness and overall health and wellness." .

feg:MuscleRegion a owl:Class ;
    rdfs:label "Muscle Region" ;
    rdfs:comment "A colloquial regional grouping of muscles used in exercise science (e.g. Shoulders, Lats, Quads). Corresponds to the coarse terms used in the source dataset." ;
    rdfs:subClassOf feg:Muscle .

feg:MovementPatternScheme a skos:ConceptScheme ;
    rdfs:label "Movement Pattern Scheme" ;
    rdfs:comment "A controlled vocabulary of fundamental human movement patterns used to classify exercises." ;
    owl:versionInfo "0.7.0" .

feg:MovementPattern a owl:Class ;
    rdfs:label "Movement Pattern" ;
    rdfs:comment "A fundamental category of human movement that describes the mechanical structure of an exercise. Exercises sharing a movement pattern make similar demands on the musculoskeletal system and may serve as substitutes for one another." .

feg:MuscleHead a owl:Class ;
    rdfs:label "Muscle Head" ;
    rdfs:comment "A distinct head, portion, or fiber region of a muscle (e.g. Anterior Deltoid, Biceps Long Head). The LLM enrichment pipeline classifies at this level where applicable." ;
    rdfs:subClassOf feg:Muscle .

feg:MuscleGroup a owl:Class ;
    rdfs:label "Muscle Group" ;
    rdfs:comment "An individual muscle or functional muscle group (e.g. Deltoid, Triceps Brachii, Erector Spinae)." ;
    rdfs:subClassOf feg:Muscle .

feg:Equipment a owl:Class ;
    rdfs:label "Equipment" ;
    rdfs:comment "A physical tool or apparatus used to perform an exercise." .

feg:JointAction a owl:Class ;
    rdfs:label "Joint Action" ;
    rdfs:comment "A biomechanical action produced at an individual joint, such as flexion, extension, abduction, or rotation. Joint actions describe movement at the level of specific joints rather than whole-exercise movement categories." .

feg:JointActionScheme a skos:ConceptScheme ;
    rdfs:label "Joint Action Scheme" ;
    rdfs:comment "A controlled vocabulary of joint actions used to describe the mechanical basis of exercises. Joint grouping nodes organise actions by joint; only leaf-level JointAction individuals should be assigned to exercises via feg:jointAction." ;
    owl:versionInfo "0.3.0" .

feg:MuscleScheme a skos:ConceptScheme ;
    rdfs:label "Muscle Vocabulary" ;
    rdfs:comment "SKOS concept scheme organizing muscles by region." ;
    owl:versionInfo "0.13.0" ;
    skos:prefLabel "Muscle Vocabulary" .

