    skos:prefLabel "Subscapularis" .

feg:Superband a owl:NamedIndividual,
        feg:Equipment ;
    rdfs:label "Superband" ;
    rdfs:comment "A large loop resistance band used for assisted pull-ups, hip activation, and banded stretching." ;
    skos:altLabel "Pull-Up Band" .

feg:Supraspinatus a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Supraspinatus" ;
    skos:broader feg:RotatorCuff ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Supraspinatus" .

feg:SuspensionTrainer a owl:NamedIndividual,
        feg:Equipment ;
    rdfs:label "Suspension Trainer" ;
    rdfs:comment "Adjustable straps anchored overhead, allowing bodyweight exercises with variable instability. Common brand: TRX." ;
    skos:altLabel "TRX" .

feg:TensorFasciaeLatae a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Tensor Fasciae Latae" ;
    skos:altLabel "TFL" ;
    skos:broader feg:Abductors ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Tensor Fasciae Latae" ;
