    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Triceps Lateral Head" .

feg:TricepsLongHead a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Triceps Long Head" ;
    skos:broader feg:TricepsBrachii ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Triceps Long Head" .

feg:TricepsMedialHead a skos:Concept,
