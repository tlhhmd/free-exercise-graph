@prefix feg: <https://placeholder.url#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

###################
# Named Individuals - Planes of Motion
###################

feg:PlanesOfMotionVocabulary
    a owl:Ontology ;
    owl:versionInfo "1.0.0" ;
.

feg:PlaneOfMotionScheme
    a skos:ConceptScheme ;
    rdfs:label "Planes of Motion" ;
    rdfs:comment "A concept scheme representing the three standard anatomical planes used to describe the primary directional orientation of human movement: Sagittal, Frontal, and Transverse." ;
.

feg:SagittalPlane
    a owl:NamedIndividual, feg:PlaneOfMotion ;
    skos:inScheme feg:PlaneOfMotionScheme ;
    rdfs:label "Sagittal Plane" ;
    rdfs:comment "The anatomical plane that divides the body into left and right portions. Movements occurring primarily in this plane are typically flexion- and extension-dominant. Examples include squats, deadlifts, biceps curls, and running." ;
.

feg:FrontalPlane
    a owl:NamedIndividual, feg:PlaneOfMotion ;
    skos:inScheme feg:PlaneOfMotionScheme ;
    rdfs:label "Frontal Plane" ;
    rdfs:comment "The anatomical plane that divides the body into anterior and posterior portions. Movements occurring primarily in this plane are typically lateral in orientation. Examples include lateral raises, lateral lunges, side shuffles, and lateral trunk flexion." ;
.

feg:TransversePlane
    a owl:NamedIndividual, feg:PlaneOfMotion ;
    skos:inScheme feg:PlaneOfMotionScheme ;
    rdfs:label "Transverse Plane" ;
    rdfs:comment "The anatomical plane that divides the body into superior and inferior portions. Movements occurring primarily in this plane are typically rotational or horizontal in orientation. Examples include Russian twists, cable wood chops, rotational medicine ball throws, and hip internal or external rotation." ;
.