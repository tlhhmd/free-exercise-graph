@prefix feg: <https://placeholder.url#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ─── Concept Scheme ───────────────────────────────────────────────────────────
# Classes (MuscleRegion, MuscleGroup, MuscleHead) are defined in ontology.ttl.
# This file contains only the SKOS concept scheme and muscle individuals.

feg:MuscleScheme a skos:ConceptScheme ;
    rdfs:label "Muscle Vocabulary" ;
    skos:prefLabel "Muscle Vocabulary" ;
    rdfs:comment "SKOS concept scheme organizing muscles by region." ;
    owl:versionInfo "0.12.0" .

# ══════════════════════════════════════════════════════════════════════════════
# SHOULDERS
# ══════════════════════════════════════════════════════════════════════════════

feg:Shoulders a feg:MuscleRegion, skos:Concept ;
    rdfs:label "Shoulders" ;
    skos:prefLabel "Shoulders" ;
    skos:inScheme feg:MuscleScheme ;
    skos:topConceptOf feg:MuscleScheme .

feg:Deltoid a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Deltoid" ;
    skos:prefLabel "Deltoid" ;
    skos:broader feg:Shoulders ;
    skos:inScheme feg:MuscleScheme .

feg:AnteriorDeltoid a feg:MuscleHead, skos:Concept ;
    rdfs:label "Anterior Deltoid" ;
    skos:prefLabel "Anterior Deltoid" ;
    skos:altLabel "Front Delt" ;
    skos:broader feg:Deltoid ;
    skos:inScheme feg:MuscleScheme .

feg:LateralDeltoid a feg:MuscleHead, skos:Concept ;
    rdfs:label "Lateral Deltoid" ;
    skos:prefLabel "Lateral Deltoid" ;
    skos:altLabel "Side Delt" ;
    skos:broader feg:Deltoid ;
    skos:inScheme feg:MuscleScheme .

feg:PosteriorDeltoid a feg:MuscleHead, skos:Concept ;
    rdfs:label "Posterior Deltoid" ;
    skos:prefLabel "Posterior Deltoid" ;
    skos:altLabel "Rear Delt" ;
    skos:broader feg:Deltoid ;
    skos:inScheme feg:MuscleScheme .

feg:RotatorCuff a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Rotator Cuff" ;
    skos:prefLabel "Rotator Cuff" ;
    feg:useGroupLevel true ;
    skos:broader feg:Shoulders ;
    skos:inScheme feg:MuscleScheme .

feg:Supraspinatus a feg:MuscleHead, skos:Concept ;
    rdfs:label "Supraspinatus" ;
    skos:prefLabel "Supraspinatus" ;
    skos:broader feg:RotatorCuff ;
    skos:inScheme feg:MuscleScheme .

feg:Infraspinatus a feg:MuscleHead, skos:Concept ;
    rdfs:label "Infraspinatus" ;
    skos:prefLabel "Infraspinatus" ;
    skos:broader feg:RotatorCuff ;
    skos:inScheme feg:MuscleScheme .

feg:TeresMinor a feg:MuscleHead, skos:Concept ;
    rdfs:label "Teres Minor" ;
    skos:prefLabel "Teres Minor" ;
    skos:broader feg:RotatorCuff ;
    skos:inScheme feg:MuscleScheme .

feg:Subscapularis a feg:MuscleHead, skos:Concept ;
    rdfs:label "Subscapularis" ;
    skos:prefLabel "Subscapularis" ;
    skos:broader feg:RotatorCuff ;
    skos:inScheme feg:MuscleScheme .

# ══════════════════════════════════════════════════════════════════════════════
# CHEST
# ══════════════════════════════════════════════════════════════════════════════

feg:Chest a feg:MuscleRegion, skos:Concept ;
    rdfs:label "Chest" ;
    skos:prefLabel "Chest" ;
    skos:altLabel "Pectorals" ;
    skos:inScheme feg:MuscleScheme ;
    skos:topConceptOf feg:MuscleScheme .

feg:PectoralisMajor a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Pectoralis Major" ;
    skos:prefLabel "Pectoralis Major" ;
    skos:altLabel "Pec Major" ;
    skos:broader feg:Chest ;
    skos:inScheme feg:MuscleScheme .

feg:ClavicularHead a feg:MuscleHead, skos:Concept ;
    rdfs:label "Clavicular Head" ;
    skos:prefLabel "Clavicular Head" ;
    skos:altLabel "Upper Chest" ;
    skos:broader feg:PectoralisMajor ;
    skos:inScheme feg:MuscleScheme .

feg:SternalHead a feg:MuscleHead, skos:Concept ;
    rdfs:label "Sternal Head" ;
    skos:prefLabel "Sternal Head" ;
    skos:altLabel "Lower Chest" ;
    skos:broader feg:PectoralisMajor ;
    skos:inScheme feg:MuscleScheme .

feg:PectoralisMinor a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Pectoralis Minor" ;
    skos:prefLabel "Pectoralis Minor" ;
    skos:altLabel "Pec Minor" ;
    skos:broader feg:Chest ;
    skos:inScheme feg:MuscleScheme .

feg:SerratusAnterior a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Serratus Anterior" ;
    skos:prefLabel "Serratus Anterior" ;
    skos:broader feg:Chest ;
    skos:inScheme feg:MuscleScheme .

# ══════════════════════════════════════════════════════════════════════════════
# LATS
# ══════════════════════════════════════════════════════════════════════════════

feg:Lats a feg:MuscleRegion, skos:Concept ;
    rdfs:label "Lats" ;
    skos:prefLabel "Lats" ;
    skos:altLabel "Latissimus Dorsi" ;
    skos:inScheme feg:MuscleScheme ;
    skos:topConceptOf feg:MuscleScheme .

feg:LatissimusDorsi a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Latissimus Dorsi" ;
    skos:prefLabel "Latissimus Dorsi" ;
    skos:altLabel "Lats" ;
    skos:broader feg:Lats ;
    skos:inScheme feg:MuscleScheme .

feg:TeresMajor a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Teres Major" ;
    skos:prefLabel "Teres Major" ;
    skos:scopeNote "Distinct from Teres Minor (rotator cuff). Acts synergistically with LatissimusDorsi in shoulder extension and adduction. Relevant on lat pulldowns, rows, and pull-up variants." ;
    skos:broader feg:Lats ;
    skos:inScheme feg:MuscleScheme .

# ══════════════════════════════════════════════════════════════════════════════
# TRAPS
# ══════════════════════════════════════════════════════════════════════════════

feg:Traps a feg:MuscleRegion, skos:Concept ;
    rdfs:label "Traps" ;
    skos:prefLabel "Traps" ;
    skos:altLabel "Trapezius" ;
    skos:inScheme feg:MuscleScheme ;
    skos:topConceptOf feg:MuscleScheme .

feg:Trapezius a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Trapezius" ;
    skos:prefLabel "Trapezius" ;
    skos:broader feg:Traps ;
    skos:inScheme feg:MuscleScheme .

feg:UpperTrapezius a feg:MuscleHead, skos:Concept ;
    rdfs:label "Upper Trapezius" ;
    skos:prefLabel "Upper Trapezius" ;
    skos:altLabel "Upper Traps" ;
    skos:broader feg:Trapezius ;
    skos:inScheme feg:MuscleScheme .

feg:MiddleTrapezius a feg:MuscleHead, skos:Concept ;
    rdfs:label "Middle Trapezius" ;
    skos:prefLabel "Middle Trapezius" ;
    skos:altLabel "Mid Traps" ;
    skos:broader feg:Trapezius ;
    skos:related feg:MiddleBack ;
    skos:inScheme feg:MuscleScheme .

feg:LowerTrapezius a feg:MuscleHead, skos:Concept ;
    rdfs:label "Lower Trapezius" ;
    skos:prefLabel "Lower Trapezius" ;
    skos:altLabel "Lower Traps" ;
    skos:broader feg:Trapezius ;
    skos:inScheme feg:MuscleScheme .

# ══════════════════════════════════════════════════════════════════════════════
# MIDDLE BACK
# ══════════════════════════════════════════════════════════════════════════════

feg:MiddleBack a feg:MuscleRegion, skos:Concept ;
    rdfs:label "Middle Back" ;
    skos:prefLabel "Middle Back" ;
    skos:inScheme feg:MuscleScheme ;
    skos:topConceptOf feg:MuscleScheme .

feg:Rhomboids a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Rhomboids" ;
    skos:prefLabel "Rhomboids" ;
    feg:useGroupLevel true ;
    skos:broader feg:MiddleBack ;
    skos:inScheme feg:MuscleScheme .

feg:RhomboidMajor a feg:MuscleHead, skos:Concept ;
    rdfs:label "Rhomboid Major" ;
    skos:prefLabel "Rhomboid Major" ;
    skos:broader feg:Rhomboids ;
    skos:inScheme feg:MuscleScheme .

feg:RhomboidMinor a feg:MuscleHead, skos:Concept ;
    rdfs:label "Rhomboid Minor" ;
    skos:prefLabel "Rhomboid Minor" ;
    skos:broader feg:Rhomboids ;
    skos:inScheme feg:MuscleScheme .

# ══════════════════════════════════════════════════════════════════════════════
# LOWER BACK
# ══════════════════════════════════════════════════════════════════════════════

feg:LowerBack a feg:MuscleRegion, skos:Concept ;
    rdfs:label "Lower Back" ;
    skos:prefLabel "Lower Back" ;
    skos:inScheme feg:MuscleScheme ;
    skos:topConceptOf feg:MuscleScheme .

feg:ErectorSpinae a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Erector Spinae" ;
    skos:prefLabel "Erector Spinae" ;
    feg:useGroupLevel true ;
    skos:broader feg:LowerBack ;
    skos:inScheme feg:MuscleScheme .

feg:Iliocostalis a feg:MuscleHead, skos:Concept ;
    rdfs:label "Iliocostalis" ;
    skos:prefLabel "Iliocostalis" ;
    skos:broader feg:ErectorSpinae ;
    skos:inScheme feg:MuscleScheme .

feg:Longissimus a feg:MuscleHead, skos:Concept ;
    rdfs:label "Longissimus" ;
    skos:prefLabel "Longissimus" ;
    skos:broader feg:ErectorSpinae ;
    skos:inScheme feg:MuscleScheme .

feg:Spinalis a feg:MuscleHead, skos:Concept ;
    rdfs:label "Spinalis" ;
    skos:prefLabel "Spinalis" ;
    skos:broader feg:ErectorSpinae ;
    skos:inScheme feg:MuscleScheme .

feg:QuadratusLumborum a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Quadratus Lumborum" ;
    skos:prefLabel "Quadratus Lumborum" ;
    skos:altLabel "QL" ;
    skos:broader feg:LowerBack ;
    skos:inScheme feg:MuscleScheme .

feg:HipFlexors a feg:MuscleRegion, skos:Concept ;
    rdfs:label "Hip Flexors" ;
    skos:prefLabel "Hip Flexors" ;
    skos:altLabel "HipFlexors" ;
    skos:scopeNote "Use only when both Psoas (Iliopsoas) and Sartorius are involved. If only one branch is active, use the specific child instead." ;
    skos:inScheme feg:MuscleScheme ;
    skos:topConceptOf feg:MuscleScheme .

feg:Psoas a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Psoas" ;
    skos:prefLabel "Psoas" ;
    skos:broader feg:HipFlexors ;
    skos:inScheme feg:MuscleScheme .

feg:Iliopsoas a feg:MuscleHead, skos:Concept ;
    rdfs:label "Iliopsoas" ;
    skos:prefLabel "Iliopsoas" ;
    skos:altLabel "Psoas Major" ;
    skos:broader feg:Psoas ;
    skos:inScheme feg:MuscleScheme .

# ══════════════════════════════════════════════════════════════════════════════
# ABDOMINALS
# ══════════════════════════════════════════════════════════════════════════════

feg:Abdominals a feg:MuscleRegion, skos:Concept ;
    rdfs:label "Abdominals" ;
    skos:prefLabel "Abdominals" ;
    skos:altLabel "Abs" ;
    skos:inScheme feg:MuscleScheme ;
    skos:topConceptOf feg:MuscleScheme .

feg:RectusAbdominis a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Rectus Abdominis" ;
    skos:prefLabel "Rectus Abdominis" ;
    skos:altLabel "Abs" ;
    skos:broader feg:Abdominals ;
    skos:inScheme feg:MuscleScheme .

feg:Obliques a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Obliques" ;
    skos:prefLabel "Obliques" ;
    feg:useGroupLevel true ;
    skos:broader feg:Abdominals ;
    skos:inScheme feg:MuscleScheme .

feg:ExternalOblique a feg:MuscleHead, skos:Concept ;
    rdfs:label "External Oblique" ;
    skos:prefLabel "External Oblique" ;
    skos:broader feg:Obliques ;
    skos:inScheme feg:MuscleScheme .

feg:InternalOblique a feg:MuscleHead, skos:Concept ;
    rdfs:label "Internal Oblique" ;
    skos:prefLabel "Internal Oblique" ;
    skos:broader feg:Obliques ;
    skos:inScheme feg:MuscleScheme .

feg:TransverseAbdominis a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Transverse Abdominis" ;
    skos:prefLabel "Transverse Abdominis" ;
    skos:altLabel "TVA" ;
    skos:broader feg:Abdominals ;
    skos:inScheme feg:MuscleScheme .

feg:Core a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Core" ;
    skos:prefLabel "Core" ;
    skos:altLabel "Anterior Core" ;
    skos:scopeNote "Convenience term for the anterior trunk as a functional unit. Use on compound movements where abdominal bracing is incidental. Use specific muscles (RectusAbdominis, Obliques, TransverseAbdominis) for dedicated core exercises where the core is the primary target." ;
    skos:broader feg:Abdominals ;
    skos:inScheme feg:MuscleScheme .

# ══════════════════════════════════════════════════════════════════════════════
# GLUTES
# ══════════════════════════════════════════════════════════════════════════════

feg:Glutes a feg:MuscleRegion, skos:Concept ;
    rdfs:label "Glutes" ;
    skos:prefLabel "Glutes" ;
    skos:altLabel "Gluteal Muscles" ;
    skos:inScheme feg:MuscleScheme ;
    skos:topConceptOf feg:MuscleScheme .

feg:GluteusMaximus a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Gluteus Maximus" ;
    skos:prefLabel "Gluteus Maximus" ;
    skos:broader feg:Glutes ;
    skos:inScheme feg:MuscleScheme .

feg:GluteusMedius a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Gluteus Medius" ;
    skos:prefLabel "Gluteus Medius" ;
    skos:broader feg:Glutes ;
    skos:related feg:Abductors ;
    skos:inScheme feg:MuscleScheme .

feg:GluteusMinimus a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Gluteus Minimus" ;
    skos:prefLabel "Gluteus Minimus" ;
    skos:broader feg:Glutes ;
    skos:related feg:Abductors ;
    skos:inScheme feg:MuscleScheme .

# ══════════════════════════════════════════════════════════════════════════════
# QUADRICEPS
# ══════════════════════════════════════════════════════════════════════════════

feg:Quadriceps a feg:MuscleRegion, skos:Concept ;
    rdfs:label "Quadriceps" ;
    skos:prefLabel "Quadriceps" ;
    skos:altLabel "Quads" ;
    skos:inScheme feg:MuscleScheme ;
    skos:topConceptOf feg:MuscleScheme .

feg:RectusFemoris a feg:MuscleHead, skos:Concept ;
    rdfs:label "Rectus Femoris" ;
    skos:prefLabel "Rectus Femoris" ;
    skos:broader feg:Quadriceps ;
    skos:related feg:HipFlexors ;
    skos:inScheme feg:MuscleScheme .

feg:VastusLateralis a feg:MuscleHead, skos:Concept ;
    rdfs:label "Vastus Lateralis" ;
    skos:prefLabel "Vastus Lateralis" ;
    skos:broader feg:Quadriceps ;
    skos:inScheme feg:MuscleScheme .

feg:VastusMedialis a feg:MuscleHead, skos:Concept ;
    rdfs:label "Vastus Medialis" ;
    skos:prefLabel "Vastus Medialis" ;
    skos:altLabel "VMO" ;
    skos:broader feg:Quadriceps ;
    skos:inScheme feg:MuscleScheme .

feg:VastusIntermedius a feg:MuscleHead, skos:Concept ;
    rdfs:label "Vastus Intermedius" ;
    skos:prefLabel "Vastus Intermedius" ;
    skos:broader feg:Quadriceps ;
    skos:inScheme feg:MuscleScheme .

feg:Sartorius a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Sartorius" ;
    skos:prefLabel "Sartorius" ;
    skos:scopeNote "Anterior thigh muscle; assists knee flexion and hip flexion. Relevant as a synergist on leg curl and hip flexion exercises." ;
    skos:broader feg:HipFlexors ;
    skos:inScheme feg:MuscleScheme .

# ══════════════════════════════════════════════════════════════════════════════
# HAMSTRINGS
# ══════════════════════════════════════════════════════════════════════════════

feg:Hamstrings a feg:MuscleRegion, skos:Concept ;
    rdfs:label "Hamstrings" ;
    skos:prefLabel "Hamstrings" ;
    skos:inScheme feg:MuscleScheme ;
    skos:topConceptOf feg:MuscleScheme .

feg:BicepsFemoris a feg:MuscleHead, skos:Concept ;
    rdfs:label "Biceps Femoris" ;
    skos:prefLabel "Biceps Femoris" ;
    skos:broader feg:Hamstrings ;
    skos:inScheme feg:MuscleScheme .

feg:Semitendinosus a feg:MuscleHead, skos:Concept ;
    rdfs:label "Semitendinosus" ;
    skos:prefLabel "Semitendinosus" ;
    skos:broader feg:Hamstrings ;
    skos:inScheme feg:MuscleScheme .

feg:Semimembranosus a feg:MuscleHead, skos:Concept ;
    rdfs:label "Semimembranosus" ;
    skos:prefLabel "Semimembranosus" ;
    skos:broader feg:Hamstrings ;
    skos:inScheme feg:MuscleScheme .

# ══════════════════════════════════════════════════════════════════════════════
# ADDUCTORS
# ══════════════════════════════════════════════════════════════════════════════

feg:Adductors a feg:MuscleRegion, skos:Concept ;
    rdfs:label "Adductors" ;
    skos:prefLabel "Adductors" ;
    skos:inScheme feg:MuscleScheme ;
    skos:topConceptOf feg:MuscleScheme .

feg:AdductorLongus a feg:MuscleHead, skos:Concept ;
    rdfs:label "Adductor Longus" ;
    skos:prefLabel "Adductor Longus" ;
    skos:broader feg:Adductors ;
    skos:inScheme feg:MuscleScheme .

feg:AdductorBrevis a feg:MuscleHead, skos:Concept ;
    rdfs:label "Adductor Brevis" ;
    skos:prefLabel "Adductor Brevis" ;
    skos:broader feg:Adductors ;
    skos:inScheme feg:MuscleScheme .

feg:AdductorMagnus a feg:MuscleHead, skos:Concept ;
    rdfs:label "Adductor Magnus" ;
    skos:prefLabel "Adductor Magnus" ;
    skos:broader feg:Adductors ;
    skos:inScheme feg:MuscleScheme .

feg:Gracilis a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Gracilis" ;
    skos:prefLabel "Gracilis" ;
    skos:broader feg:Adductors ;
    skos:inScheme feg:MuscleScheme .

# ══════════════════════════════════════════════════════════════════════════════
# ABDUCTORS
# ══════════════════════════════════════════════════════════════════════════════

feg:Abductors a feg:MuscleRegion, skos:Concept ;
    rdfs:label "Abductors" ;
    skos:prefLabel "Abductors" ;
    skos:inScheme feg:MuscleScheme ;
    skos:topConceptOf feg:MuscleScheme .

feg:TensorFasciaeLatae a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Tensor Fasciae Latae" ;
    skos:prefLabel "Tensor Fasciae Latae" ;
    skos:altLabel "TFL" ;
    skos:broader feg:Abductors ;
    skos:related feg:HipFlexors ;
    skos:inScheme feg:MuscleScheme .

# Note: GluteusMedius and GluteusMinimus are defined under Glutes
# with skos:related feg:Abductors per ADR-020.

# ══════════════════════════════════════════════════════════════════════════════
# CALVES
# ══════════════════════════════════════════════════════════════════════════════

feg:LowerLeg a feg:MuscleRegion, skos:Concept ;
    rdfs:label "Lower Leg" ;
    skos:prefLabel "Lower Leg" ;
    skos:inScheme feg:MuscleScheme ;
    skos:topConceptOf feg:MuscleScheme .

feg:Calves a feg:MuscleRegion, skos:Concept ;
    rdfs:label "Calves" ;
    skos:prefLabel "Calves" ;
    skos:broader feg:LowerLeg ;
    skos:inScheme feg:MuscleScheme .

feg:Gastrocnemius a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Gastrocnemius" ;
    skos:prefLabel "Gastrocnemius" ;
    feg:useGroupLevel true ;
    skos:broader feg:Calves ;
    skos:inScheme feg:MuscleScheme .

feg:MedialGastrocnemius a feg:MuscleHead, skos:Concept ;
    rdfs:label "Medial Gastrocnemius" ;
    skos:prefLabel "Medial Gastrocnemius" ;
    skos:broader feg:Gastrocnemius ;
    skos:inScheme feg:MuscleScheme .

feg:LateralGastrocnemius a feg:MuscleHead, skos:Concept ;
    rdfs:label "Lateral Gastrocnemius" ;
    skos:prefLabel "Lateral Gastrocnemius" ;
    skos:broader feg:Gastrocnemius ;
    skos:inScheme feg:MuscleScheme .

feg:Soleus a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Soleus" ;
    skos:prefLabel "Soleus" ;
    skos:broader feg:Calves ;
    skos:inScheme feg:MuscleScheme .

feg:TibialisAnterior a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Tibialis Anterior" ;
    skos:prefLabel "Tibialis Anterior" ;
    skos:altLabel "Tibialis" ;
    skos:broader feg:LowerLeg ;
    skos:inScheme feg:MuscleScheme .

feg:Shins a feg:MuscleRegion, skos:Concept ;
    rdfs:label "Shins" ;
    skos:prefLabel "Shins" ;
    rdfs:comment "Colloquial term for the anterior lower leg compartment. Contains the muscles responsible for ankle dorsiflexion and toe extension." ;
    skos:broader feg:LowerLeg ;
    skos:inScheme feg:MuscleScheme .

feg:ExtensorDigitorumLongus a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Extensor Digitorum Longus" ;
    skos:prefLabel "Extensor Digitorum Longus" ;
    rdfs:comment "Anterior lower leg muscle responsible for toe extension and ankle dorsiflexion." ;
    skos:broader feg:Shins ;
    skos:inScheme feg:MuscleScheme .

feg:ExtensorHallucisLongus a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Extensor Hallucis Longus" ;
    skos:prefLabel "Extensor Hallucis Longus" ;
    rdfs:comment "Anterior lower leg muscle responsible for big toe extension and ankle dorsiflexion." ;
    skos:broader feg:Shins ;
    skos:inScheme feg:MuscleScheme .

feg:TibialisPosterior a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Tibialis Posterior" ;
    skos:prefLabel "Tibialis Posterior" ;
    rdfs:comment "Deep posterior lower leg muscle responsible for ankle inversion and plantarflexion." ;
    skos:broader feg:LowerLeg ;
    skos:inScheme feg:MuscleScheme .

feg:Peroneals a feg:MuscleRegion, skos:Concept ;
    rdfs:label "Peroneals" ;
    skos:prefLabel "Peroneals" ;
    skos:altLabel "Fibularis" ;
    rdfs:comment "Lateral compartment of the lower leg. Responsible for ankle eversion and assist plantarflexion." ;
    skos:broader feg:LowerLeg ;
    skos:inScheme feg:MuscleScheme .

feg:PeroneusLongus a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Peroneus Longus" ;
    skos:prefLabel "Peroneus Longus" ;
    skos:altLabel "Fibularis Longus" ;
    rdfs:comment "Lateral lower leg muscle. Everts the ankle and assists plantarflexion. Active as a synergist on calf raises and single-leg stability work." ;
    skos:broader feg:Peroneals ;
    skos:inScheme feg:MuscleScheme .

feg:PeroneusBrevis a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Peroneus Brevis" ;
    skos:prefLabel "Peroneus Brevis" ;
    skos:altLabel "Fibularis Brevis" ;
    rdfs:comment "Lateral lower leg muscle. Primary evertor of the ankle; assists plantarflexion." ;
    skos:broader feg:Peroneals ;
    skos:inScheme feg:MuscleScheme .

feg:FlexorHallucisLongus a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Flexor Hallucis Longus" ;
    skos:prefLabel "Flexor Hallucis Longus" ;
    rdfs:comment "Deep posterior lower leg muscle. Flexes the big toe and assists plantarflexion. Relevant on calf raises and push-off movements." ;
    skos:broader feg:LowerLeg ;
    skos:inScheme feg:MuscleScheme .

feg:FlexorDigitorumLongus a feg:MuscleGroup, skos:Concept ;
    rdfs:label "Flexor Digitorum Longus" ;
    skos:prefLabel "Flexor Digitorum Longus" ;
    rdfs:comment "Deep posterior lower leg muscle. Flexes the lesser toes and assists plantarflexion and ankle inversion." ;
    skos:broader feg:LowerLeg ;
    skos:inScheme feg:MuscleScheme .

