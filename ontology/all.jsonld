      {
        "@id": "https://placeholder.url#Ankle"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#JointActionScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Dorsiflexion"
      }
    ]
  },
