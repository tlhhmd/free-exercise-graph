    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@value": "Distinct from Teres Minor (rotator cuff). Acts synergistically with LatissimusDorsi in shoulder extension and adduction. Relevant on lat pulldowns, rows, and pull-up variants."
      }
    ]
  },
