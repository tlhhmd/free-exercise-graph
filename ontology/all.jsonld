      }
    ]
  },
  {
    "@id": "https://placeholder.url#KneeExtension",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#JointAction",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Straightening the knee to increase the angle between the lower and upper leg. Primary drivers: quadriceps."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Knee Extension"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#Knee"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#JointActionScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Knee Extension"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#muscle",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Prefer the most specific term available: MuscleHead > MuscleGroup > MuscleRegion. Use a region term only if no group applies; use a group term only if no head applies. Exception: groups marked useGroupLevel=true are the correct term — do not descend to their heads. Exception: Core (a MuscleGroup under Abdominals) is a convenience term permitted on compound movements where abdominal bracing is incidental; it must always be assigned as Stabilizer. Critical: joint action concept names (e.g. ScapularUpwardRotation, HipFlexion, ElbowFlexion, ScapularRetraction) are NOT muscle names — never use a joint action concept as a muscle value. TricepsBrachii (group) must not be used — always decompose into TricepsLongHead, TricepsLateralHead, and TricepsMedialHead, including for Stabilizer and Synergist roles; TricepsLongHead is meaningfully distinct as it crosses the shoulder joint. On Mobility exercises and passive stretches, minimise Stabilizers — include one only when there is a clear active stabilisation demand; do not routinely add Core or RotatorCuff. A muscle may not appear more than once across an exercise's involvements — if the same muscle would be assigned at two different degrees, use the higher-priority degree only (PrimeMover > Synergist > Stabilizer). An exercise may not list both a muscle and any of its SKOS ancestors — this double-counts the same muscle mass; use the most specific term only."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://placeholder.url#MuscleInvolvement"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "muscle"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://placeholder.url#Muscle"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#SlantBoard",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#Equipment"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An angled platform that elevates the heels, used for cyclist squats and ankle mobility work."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Slant Board"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#HorizontalPush",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "http://www.w3.org/2004/02/skos/core#Concept",
      "https://placeholder.url#MovementPattern"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Movements in which force is produced by pushing horizontally away from the body, principally targeting the chest, anterior deltoid, and triceps."
