      }
    ]
  },
  {
    "@id": "_:n80fee75296ad4b25ad2c1c04c1eeb978b22",
    "http://www.w3.org/ns/shacl#in": [
      {
        "@list": [
          {
            "@id": "https://placeholder.url#PrimeMover"
          },
          {
            "@id": "https://placeholder.url#Synergist"
          },
          {
            "@id": "https://placeholder.url#Stabilizer"
          },
          {
            "@id": "https://placeholder.url#PassiveTarget"
          }
        ]
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Degree must be one of: PrimeMover, Synergist, Stabilizer, PassiveTarget."
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://placeholder.url#degree"
      }
    ]
  },
  {
    "@id": "_:na2c2149848514fb1815e204621bf10ecb30",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "A muscle involvement's feg:muscle value is a JointAction individual, not a Muscle. Joint action concept names (e.g. ScapularUpwardRotation, ScapularRetraction, HipFlexion) describe movement at a joint — they are not muscles. Check the muscle hierarchy for the correct muscle name."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\n            SELECT $this WHERE {\n                $this feg:muscle ?muscle .\n                ?muscle rdf:type feg:JointAction .\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:na2c2149848514fb1815e204621bf10ecb31",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "A MuscleInvolvement must be referenced by at least one Exercise via hasInvolvement."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            SELECT $this WHERE {\n                FILTER NOT EXISTS {\n                    ?exercise feg:hasInvolvement $this .\n                }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:na2c2149848514fb1815e204621bf10ecb32",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Core must be assigned as Stabilizer only. For dedicated core exercises where the abdominals are the primary target, use specific muscles (RectusAbdominis, Obliques, TransverseAbdominis) instead."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            SELECT $this WHERE {\n                $this feg:muscle feg:Core .\n                $this feg:degree ?degree .\n                FILTER (?degree != feg:Stabilizer)\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:na2c2149848514fb1815e204621bf10ecb33",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "This involvement references a muscle head whose parent group has useGroupLevel=true. Use the group-level term instead."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            PREFIX skos: <http://www.w3.org/2004/02/skos/core#>\n            SELECT $this WHERE {\n                $this feg:muscle ?head .\n                ?head skos:broader ?group .\n                ?group feg:useGroupLevel true .\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:n80fee75296ad4b25ad2c1c04c1eeb978b27",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "A muscle involvement's feg:muscle value is a JointAction individual, not a Muscle. Joint action concept names (e.g. ScapularUpwardRotation, ScapularRetraction, HipFlexion) describe movement at a joint — they are not muscles. Check the muscle hierarchy for the correct muscle name."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\n            SELECT $this WHERE {\n                $this feg:muscle ?muscle .\n                ?muscle rdf:type feg:JointAction .\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:n80fee75296ad4b25ad2c1c04c1eeb978b28",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "A MuscleInvolvement must be referenced by at least one Exercise via hasInvolvement."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            SELECT $this WHERE {\n                FILTER NOT EXISTS {\n                    ?exercise feg:hasInvolvement $this .\n                }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:n80fee75296ad4b25ad2c1c04c1eeb978b29",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Core must be assigned as Stabilizer only. For dedicated core exercises where the abdominals are the primary target, use specific muscles (RectusAbdominis, Obliques, TransverseAbdominis) instead."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            SELECT $this WHERE {\n                $this feg:muscle feg:Core .\n                $this feg:degree ?degree .\n                FILTER (?degree != feg:Stabilizer)\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:n80fee75296ad4b25ad2c1c04c1eeb978b30",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "This involvement references a muscle head whose parent group has useGroupLevel=true. Use the group-level term instead."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            PREFIX skos: <http://www.w3.org/2004/02/skos/core#>\n            SELECT $this WHERE {\n                $this feg:muscle ?head .\n                ?head skos:broader ?group .\n                ?group feg:useGroupLevel true .\n            }\n        "
      }
    ]
  },
  {
    "@id": "https://placeholder.url#Rotation",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "http://www.w3.org/2004/02/skos/core#Concept",
      "https://placeholder.url#MovementPattern"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Movements involving rotation or anti-rotation of the trunk, principally targeting the obliques and deep core musculature."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Rotation"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#MovementPatternScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Rotation"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#Elbow",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Grouping node for elbow joint actions."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Elbow"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#JointActionScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Elbow"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#Spinalis",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept",
      "https://placeholder.url#MuscleHead"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Spinalis"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#ErectorSpinae"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#MuscleScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Spinalis"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#AntiExtension",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "http://www.w3.org/2004/02/skos/core#Concept",
      "https://placeholder.url#MovementPattern"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Exercises that train the trunk to resist extension forces — the spine is braced against a load that attempts to extend it. Representative: plank, ab wheel rollout, dead bug, hollow hold."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Anti Extension"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#TrunkStability"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#MovementPatternScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Anti Extension"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#MuscleRegion",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A colloquial regional grouping of muscles used in exercise science (e.g. Shoulders, Lats, Quads). Corresponds to the coarse terms used in the source dataset."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Muscle Region"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://placeholder.url#Muscle"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An ontology for exercise science, extending free-exercise-db with semantic properties."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Free Exercise Graph Ontology"
      }
    ],
    "http://www.w3.org/2002/07/owl#versionInfo": [
      {
        "@value": "1.0.1"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#FlexorCarpiUlnaris",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept",
      "https://placeholder.url#MuscleHead"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Flexor Carpi Ulnaris"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#WristFlexors"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#MuscleScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Flexor Carpi Ulnaris"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#HipAbduction",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#JointAction",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Moving the thigh outward away from the midline in the frontal plane. Primary drivers: gluteus medius, gluteus minimus, tensor fasciae latae."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Hip Abduction"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#Hip"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#JointActionScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Hip Abduction"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#InvolvementDegree",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A classification describing the role a muscle plays in an exercise."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Involvement Degree"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#supportingJointAction",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Assign joint actions that contribute meaningfully but are not the defining stimulus — only those relevant for substitution decisions, fatigue accumulation, or inter-muscular coordination. This is not a biomechanical inventory: omit incidental or purely stabilising actions. Leave empty if nothing qualifies. Typically 0–3 per exercise. Leaf-level concepts only. Setup-position rule: do not assign joint actions that describe the starting position of the exercise — only actions that occur during the movement itself. Examples: bent knees at the start of a glute bridge are setup, not KneeFlexion as a joint action; semi-locked knees during a good morning are setup, not a movement action. Ankle mechanics for sagittal plane lifts: for squats, deadlifts, and lunges the relevant ankle action is Dorsiflexion (the ankle dorsiflexes to allow depth). AnkleEversion and AnkleInversion are movement faults, not defining supporting actions in these exercises."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://placeholder.url#Exercise"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "supporting joint action"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://placeholder.url#JointAction"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://placeholder.url#jointAction"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#Mobility",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "http://www.w3.org/2004/02/skos/core#Concept",
      "https://placeholder.url#MovementPattern",
      "https://placeholder.url#TrainingModality"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Static and dynamic stretching, flexibility work, and range of motion exercises. Distinct from SoftTissue, which covers foam rolling and myofascial release."
      },
      {
        "@value": "Training principally focused on improving range of motion and movement quality at a joint or across multiple joints."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Mobility"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#MovementPatternScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Mobility"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#PassiveTarget",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#InvolvementDegree"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A muscle that is the passive target of a stretch or soft tissue technique. Used in Mobility and SoftTissue exercises where the muscle is being lengthened or treated rather than actively contracting. Exercises with at least one PassiveTarget involvement are exempt from the PrimeMover requirement. Synergists and Stabilizers may still be present if other muscles are actively engaged."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Passive Target"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#ErectorSpinae",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept",
      "https://placeholder.url#MuscleGroup"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Erector Spinae"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#LowerBack"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#MuscleScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Erector Spinae"
      }
    ],
    "https://placeholder.url#useGroupLevel": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#boolean",
        "@value": true
      }
    ]
  },
  {
    "@id": "https://placeholder.url#Laterality",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Describes how limb involvement is distributed across the left and right sides of the body. Four values: Bilateral, Unilateral, Contralateral, Ipsilateral. See laterality.ttl for named individuals."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Laterality"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#Locomotion",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "http://www.w3.org/2004/02/skos/core#Concept",
      "https://placeholder.url#MovementPattern"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Movements involving whole-body travel through space, including running, jumping, and crawling patterns."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Locomotion"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#MovementPatternScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Locomotion"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#Unilateral",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#Laterality"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "One limb works at a time, independently of the other. Examples: single-leg squat, single-arm dumbbell row, single-leg Romanian deadlift."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Unilateral"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#LateralityScheme"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#SpinalFlexion",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#JointAction",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Rounding the spine forward, reducing the angle between the torso and thighs. Primary drivers: rectus abdominis, obliques."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Spinal Flexion"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#Spine"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#JointActionScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Spinal Flexion"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#CoreFlexion",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "http://www.w3.org/2004/02/skos/core#Concept",
      "https://placeholder.url#MovementPattern"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Exercises that produce dynamic spinal flexion under load — the trunk actively shortens against resistance. Distinct from the joint action SpinalFlexion: this is the user-facing exercise category (crunch, sit-up, cable crunch, hanging leg raise), not the biomechanical descriptor. Representative: crunches, sit-ups, cable crunches, V-ups, hanging leg raises."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Core Flexion"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#TrunkStability"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#MovementPatternScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Core Flexion"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#ScapularDownwardRotation",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#JointAction",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Rotating the scapula so the glenoid points downward, returning from an overhead position. Primary drivers: rhomboids, levator scapulae, pectoralis minor."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Scapular Downward Rotation"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#Scapula"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#JointActionScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Scapular Downward Rotation"
      }
    ]
  },
