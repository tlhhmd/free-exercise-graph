  {
    "@id": "https://placeholder.url#SagittalPlane",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#PlaneOfMotion"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The anatomical plane that divides the body into left and right portions. Movements occurring primarily in this plane are typically flexion- and extension-dominant. Examples include squats, deadlifts, biceps curls, and running."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Sagittal Plane"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#PlaneOfMotionScheme"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#degree",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "PrimeMover: the muscle directly produces the exercise's defining movement. Synergist: assists or fine-tunes the prime mover. Stabilizer: isometrically holds a joint or segment — does not contribute to the primary movement. PassiveTarget: tissue being lengthened or mobilised — Mobility and SoftTissue exercises only. Every exercise must have at least one PrimeMover, or at least one PassiveTarget for Mobility and SoftTissue exercises. Core must always be assigned as Stabilizer — for dedicated core exercises where the abdominals are the primary target, use specific muscles (RectusAbdominis, Obliques, TransverseAbdominis) instead."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://placeholder.url#MuscleInvolvement"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "degree"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://placeholder.url#InvolvementDegree"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#Dorsiflexion",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#JointAction",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
