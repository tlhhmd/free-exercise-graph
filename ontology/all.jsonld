    "@id": "https://placeholder.url#JointAction",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A biomechanical action produced at an individual joint, such as flexion, extension, abduction, or rotation. Joint actions describe movement at the level of specific joints rather than whole-exercise movement categories."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
