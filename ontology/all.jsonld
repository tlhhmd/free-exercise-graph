    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#PectoralisMajor"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#MuscleScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Clavicular Head"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#PrimeMover",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#InvolvementDegree"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The muscle whose primary biomechanical action directly produces the exercise's defining joint action(s). The prime mover is the intended training target — the muscle the exercise is designed to develop. A muscle that is active but contributes via a secondary action should be Synergist instead. Example: LateralDeltoid's primary action is shoulder abduction; it should not be PrimeMover on a pressing or throwing exercise where ShoulderFlexion is the defining action. When multiple muscles share the same primary joint action (e.g. all four quadriceps heads all producing KneeExtension), all may be PrimeMover — they will be consolidated into the parent group post-ingestion by repair_04. Exception for explosive hip extension movements (cleans, snatches, jumps): GluteusMaximus is the primary PrimeMover. Hamstrings contribute to hip extension but are biarticular and are better classified Synergist in these movements."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Prime Mover"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#Strength",
