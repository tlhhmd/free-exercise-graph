  {
    "@id": "https://placeholder.url#Carry",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "http://www.w3.org/2004/02/skos/core#Concept",
      "https://placeholder.url#MovementPattern"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Movements in which load is held and transported through space, demanding full-body stability and grip strength."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Carry"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#MovementPatternScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Carry"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#useGroupLevel",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Indicates that this MuscleGroup functions as a single training unit — its constituent muscles cannot be selectively recruited or meaningfully targeted independently through exercise selection. The group term is the appropriate level of specificity; the individual head-level concepts exist for anatomical completeness but do not represent distinct training outcomes."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://placeholder.url#MuscleGroup"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "use group level"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#editorialNote": [
      {
        "@value": "Used by the classification pipeline to enforce group-level usage. Groups with this flag are surfaced in the prompt as explicit exceptions to the head-preference rule, and a SHACL constraint rejects any classification that references one of their child heads."
      }
    ]
  },
  {
    "@id": "https://placeholder.url#LateralLocomotion",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "http://www.w3.org/2004/02/skos/core#Concept",
      "https://placeholder.url#MovementPattern"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Movements involving side-to-side travel through space. Representative: lateral shuffle, lateral bound, side-step."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Lateral Locomotion"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#Locomotion"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#MovementPatternScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Lateral Locomotion"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#exerciseStyle",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The training system, tradition, or methodological context the exercise belongs to. Assign only when the exercise has a clear home in a named tradition (e.g. a Turkish Get-Up is unambiguously Grinds/kettlebell; a barbell back squat is not exclusively Powerlifting). Do not assign when the exercise is generic. Multiple styles permitted where genuinely appropriate."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://placeholder.url#Exercise"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "exercise style"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://placeholder.url#ExerciseStyle"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#isCombination",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Set to true when the exercise is a deliberate sequence of two independent movements performed as one (e.g. squat-to-press, deadlift-to-row, lunge-to-curl). Distinct from feg:isCompound, which refers to joint mechanics. A combination exercise is always compound, but a compound exercise is not necessarily a combination. Omit or set to false for single-movement exercises."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://placeholder.url#Exercise"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "is combination"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#Balance",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#ExerciseStyle"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Exercises whose primary demand is proprioceptive and vestibular challenge. The defining stimulus is maintaining equilibrium under load or in unstable conditions, not muscle development or cardiovascular adaptation."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Balance"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#ExerciseStyleScheme"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#HipHorizontalAdduction",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#JointAction",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Moving the thigh toward the midline in the transverse plane when the hip is already flexed to approximately 90°. Distinct from frontal-plane adduction. Primary drivers: adductors, pectineus."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Hip Horizontal Adduction"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#Hip"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#JointActionScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Hip Horizontal Adduction"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#HipHinge",
