[
  {
    "@id": "https://placeholder.url#Calisthenics",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#ExerciseStyle"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Bodyweight exercises using gymnastic and street workout principles. Emphasis on relative strength, movement skill, and progressive overload through leverage rather than external load."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Calisthenics"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#ExerciseStyleScheme"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#Pull",
