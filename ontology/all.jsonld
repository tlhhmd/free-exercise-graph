      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Piriformis"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@value": "Deep hip external rotator located beneath the gluteal region. Grouped under Glutes for exercise-facing usability, not strict anatomical classification. Primary action: external rotation of the femur. Commonly targeted by clamshell variations and hip external rotation drills."
      }
    ]
  },
  {
    "@id": "https://placeholder.url#TeresMajor",
    "@type": [
