  },
  {
    "@id": "_:n80fee75296ad4b25ad2c1c04c1eeb978b32",
    "http://www.w3.org/ns/shacl#hasValue": [
      {
        "@id": "https://placeholder.url#JointActionScheme"
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "A joint action must be in feg:JointActionScheme."
