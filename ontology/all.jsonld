      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "http://www.w3.org/2004/02/skos/core#Concept",
      "https://placeholder.url#MovementPattern"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Movements in which force is produced by pulling load toward the body."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Pull"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#MovementPatternScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Pull"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#Hypertrophy",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#TrainingModality"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Training principally focused on increasing muscle size through moderate loads and moderate to high repetitions."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Hypertrophy"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#HipAdduction",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#JointAction",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Moving the thigh inward toward and across the midline. Primary drivers: adductor magnus, adductor longus, adductor brevis, gracilis."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Hip Adduction"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#Hip"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#JointActionScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Hip Adduction"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#SpinalStability",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#JointAction",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Isometric resistance of spinal movement under external load — the spine does not move, it braces against a destabilising force. The direction of the resisted force (extension, rotation, lateral flexion) is captured by the movement pattern (AntiExtension, AntiRotation, AntiLateralFlexion). Primary drivers: deep core musculature, transverse abdominis, multifidus."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Spinal Stability"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#Spine"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#JointActionScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Spinal Stability"
      }
    ]
  },
