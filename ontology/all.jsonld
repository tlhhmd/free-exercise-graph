        "@id": "https://placeholder.url#exerciseStyle"
      }
    ]
  },
  {
    "@id": "_:n80fee75296ad4b25ad2c1c04c1eeb978b15",
    "http://www.w3.org/ns/shacl#class": [
      {
        "@id": "https://placeholder.url#JointAction"
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Primary joint action must be a known JointAction individual."
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://placeholder.url#primaryJointAction"
      }
    ]
  },
  {
    "@id": "_:n80fee75296ad4b25ad2c1c04c1eeb978b16",
    "http://www.w3.org/ns/shacl#class": [
      {
        "@id": "https://placeholder.url#JointAction"
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Supporting joint action must be a known JointAction individual."
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://placeholder.url#supportingJointAction"
      }
    ]
  },
  {
    "@id": "_:n80fee75296ad4b25ad2c1c04c1eeb978b18",
    "http://www.w3.org/ns/shacl#datatype": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#boolean"
      }
    ],
    "http://www.w3.org/ns/shacl#maxCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "isCompound must be a single boolean value."
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://placeholder.url#isCompound"
      }
    ]
  },
  {
    "@id": "_:na2c2149848514fb1815e204621bf10ecb15",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "A joint action may not appear in both primaryJointAction and supportingJointAction."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            SELECT $this WHERE {\n                $this feg:primaryJointAction ?ja ;\n                      feg:supportingJointAction ?ja .\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:na2c2149848514fb1815e204621bf10ecb16",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "An exercise may not assign both a muscle and one of its ancestors — this double-counts the same muscle mass. Use the most specific term only."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            PREFIX skos: <http://www.w3.org/2004/02/skos/core#>\n            SELECT $this WHERE {\n                $this feg:hasInvolvement ?inv1 ;\n                      feg:hasInvolvement ?inv2 .\n                ?inv1 feg:muscle ?child .\n                ?inv2 feg:muscle ?ancestor .\n                FILTER (?inv1 != ?inv2)\n                ?child skos:broader+ ?ancestor .\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:na2c2149848514fb1815e204621bf10ecb17",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "An exercise must have at least one PrimeMover involvement, or at least one PassiveTarget involvement for Mobility and SoftTissue exercises."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            SELECT $this WHERE {\n                FILTER NOT EXISTS {\n                    $this feg:hasInvolvement ?inv .\n                    ?inv feg:degree feg:PrimeMover .\n                }\n                FILTER NOT EXISTS {\n                    $this feg:hasInvolvement ?inv .\n                    ?inv feg:degree feg:PassiveTarget .\n                }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:na2c2149848514fb1815e204621bf10ecb18",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "An exercise must have at least one primaryJointAction, unless it has only PassiveTarget involvements (Mobility/SoftTissue exercises)."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            SELECT $this WHERE {\n                FILTER NOT EXISTS {\n                    $this feg:primaryJointAction ?ja .\n                }\n                FILTER NOT EXISTS {\n                    $this feg:hasInvolvement ?inv .\n                    ?inv feg:degree feg:PassiveTarget .\n                }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:na2c2149848514fb1815e204621bf10ecb19",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "A muscle may not appear more than once across an exercise's muscle involvements."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            SELECT $this WHERE {\n                $this feg:hasInvolvement ?inv1 ;\n                      feg:hasInvolvement ?inv2 .\n                ?inv1 feg:muscle ?muscle .\n                ?inv2 feg:muscle ?muscle .\n                FILTER (?inv1 != ?inv2)\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:n80fee75296ad4b25ad2c1c04c1eeb978b4",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "An exercise must have at least one PrimeMover involvement, or at least one PassiveTarget involvement for Mobility and SoftTissue exercises."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            SELECT $this WHERE {\n                FILTER NOT EXISTS {\n                    $this feg:hasInvolvement ?inv .\n                    ?inv feg:degree feg:PrimeMover .\n                }\n                FILTER NOT EXISTS {\n                    $this feg:hasInvolvement ?inv .\n                    ?inv feg:degree feg:PassiveTarget .\n                }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:n80fee75296ad4b25ad2c1c04c1eeb978b5",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "An exercise must have at least one primaryJointAction, unless it has only PassiveTarget involvements (Mobility/SoftTissue exercises)."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            SELECT $this WHERE {\n                FILTER NOT EXISTS {\n                    $this feg:primaryJointAction ?ja .\n                }\n                FILTER NOT EXISTS {\n                    $this feg:hasInvolvement ?inv .\n                    ?inv feg:degree feg:PassiveTarget .\n                }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:n80fee75296ad4b25ad2c1c04c1eeb978b6",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "A muscle may not appear more than once across an exercise's muscle involvements."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            SELECT $this WHERE {\n                $this feg:hasInvolvement ?inv1 ;\n                      feg:hasInvolvement ?inv2 .\n                ?inv1 feg:muscle ?muscle .\n                ?inv2 feg:muscle ?muscle .\n                FILTER (?inv1 != ?inv2)\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:n80fee75296ad4b25ad2c1c04c1eeb978b17",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "A joint action may not appear in both primaryJointAction and supportingJointAction."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            SELECT $this WHERE {\n                $this feg:primaryJointAction ?ja ;\n                      feg:supportingJointAction ?ja .\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:n80fee75296ad4b25ad2c1c04c1eeb978b19",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "An exercise may not assign both a muscle and one of its ancestors — this double-counts the same muscle mass. Use the most specific term only."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            PREFIX feg: <https://placeholder.url#>\n            PREFIX skos: <http://www.w3.org/2004/02/skos/core#>\n            SELECT $this WHERE {\n                $this feg:hasInvolvement ?inv1 ;\n                      feg:hasInvolvement ?inv2 .\n                ?inv1 feg:muscle ?child .\n                ?inv2 feg:muscle ?ancestor .\n                FILTER (?inv1 != ?inv2)\n                ?child skos:broader+ ?ancestor .\n            }\n        "
      }
    ]
  },
  {
    "@id": "https://placeholder.url#Cable",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#Equipment"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A pulley-based cable machine providing constant tension through the range of motion."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Cable"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#ExerciseStyle",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The training system, tradition, or methodological context an exercise belongs to. Distinct from feg:TrainingModality, which describes physiological adaptation. See exercise_styles.ttl for named individuals."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Exercise Style"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#Shins",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept",
      "https://placeholder.url#MuscleRegion"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Colloquial term for the anterior lower leg compartment. Contains the muscles responsible for ankle dorsiflexion and toe extension."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Shins"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#LowerLeg"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#MuscleScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Shins"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#Peroneals",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept",
      "https://placeholder.url#MuscleRegion"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Lateral compartment of the lower leg. Responsible for ankle eversion and assist plantarflexion."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Peroneals"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@value": "Fibularis"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#LowerLeg"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#MuscleScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Peroneals"
      }
    ]
  },
