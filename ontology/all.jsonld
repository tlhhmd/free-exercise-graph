    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@value": "Convenience term for the anterior trunk as a functional unit. Use on compound movements where abdominal bracing is incidental. Use specific muscles (RectusAbdominis, Obliques, TransverseAbdominis) for dedicated core exercises where the core is the primary target."
      }
    ]
