      "https://placeholder.url#MovementPattern"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Exercises whose defining characteristic is maintaining a static position under load rather than producing movement through a range of motion. Representative: wall sit, loaded carry (static component), L-sit, bar hang. Distinct from Anti-Extension and Anti-Rotation, which are specific trunk resistance patterns."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
