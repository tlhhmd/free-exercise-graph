      "https://placeholder.url#PlaneOfMotion"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The anatomical plane that divides the body into superior and inferior portions. Movements occurring primarily in this plane are typically rotational or horizontal in orientation. Examples include Russian twists, cable wood chops, rotational medicine ball throws, and hip internal or external rotation."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
