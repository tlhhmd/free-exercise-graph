      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Lateral Deltoid"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#Forearm",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Grouping node for radioulnar joint actions."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Forearm"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#JointActionScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Forearm"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#HipCircumduction",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#JointAction",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Circular or conical movement of the femur combining sequential hip flexion, abduction, extension, and adduction. Occurs in leg circles, hip CARs, and certain mobility drills. Engages the full hip musculature through its range."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Hip Circumduction"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#Hip"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#JointActionScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Hip Circumduction"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#LowerBack",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept",
      "https://placeholder.url#MuscleRegion"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Lower Back"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#MuscleScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Lower Back"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://placeholder.url#MuscleScheme"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#ScapularUpwardRotation",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#JointAction",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Rotating the scapula so the glenoid points upward to allow overhead reach. Occurs in all overhead pressing and pulling movements. Primary drivers: upper and lower trapezius, serratus anterior."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Scapular Upward Rotation"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#Scapula"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#JointActionScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Scapular Upward Rotation"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#ShoulderAdduction",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#JointAction",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Pulling the arm back toward and across the midline in the frontal plane. Primary drivers: latissimus dorsi, pectoralis major, teres major."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Shoulder Adduction"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://placeholder.url#Shoulder"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://placeholder.url#JointActionScheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Shoulder Adduction"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#MovementPatternScheme",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#ConceptScheme"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A controlled vocabulary of fundamental human movement patterns used to classify exercises."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Movement Pattern Scheme"
      }
    ],
    "http://www.w3.org/2002/07/owl#versionInfo": [
      {
        "@value": "0.7.0"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#Power",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#TrainingModality"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Training principally focused on developing rate of force development under load. The defining exercises are Olympic lifts and their derivatives: clean, snatch, jerk, and their hang, power, and split variants. Distinct from Plyometrics: explosive force production under load, no stretch-shortening cycle."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Power"
      }
    ]
  },
  {
    "@id": "https://placeholder.url#TricepsLongHead",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept",
      "https://placeholder.url#MuscleHead"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Triceps Long Head"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
