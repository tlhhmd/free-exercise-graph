  {
    "@id": "https://placeholder.url#AnimalFlow",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://placeholder.url#ExerciseStyle"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A ground-based movement practice inspired by animal locomotion patterns. Emphasises mobility, coordination, and movement flow across multiple planes."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Animal Flow"
      }
    ],
