@prefix feg: <https://placeholder.url#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

feg:ShapesGraph
    a owl:Ontology ;
    rdfs:label "Free Exercise Graph SHACL Shapes" ;
    owl:versionInfo "0.8.0" ;
.

###################
# ExerciseShape
###################

feg:ExerciseShape
    a sh:NodeShape ;
    sh:targetClass feg:Exercise ;
    rdfs:label "Exercise Shape" ;
    rdfs:comment "Validates that every Exercise individual is correctly and completely described." ;

    # must have exactly one rdfs:label
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "An exercise must have exactly one rdfs:label." ;
    ] ;

    # movement pattern — optional; when present must be a known MovementPattern individual.
    # Isolation exercises that don't fit any pattern (e.g. hip adduction, lying leg curl)
    # should return an empty array rather than force an ill-fitting pattern.
    sh:property [
        sh:path feg:movementPattern ;
        sh:minCount 0 ;
        sh:class feg:MovementPattern ;
        sh:message "Movement pattern must be a known MovementPattern individual." ;
        rdfs:comment "Use the most specific pattern that applies — prefer child patterns over parent patterns (e.g. Squat over KneeDominant, HorizontalPush over Push). Use a parent only when no child fits. Compound exercises may have more than one pattern. If no pattern fits well, return an empty array — do not force an ill-fitting label. Isolation exercises that are not curls, rows, presses, or hinges often have no clean pattern. Push and Pull patterns require multi-joint force production. Single-joint isolation movements (bicep curls, lateral raises, triceps extensions, leg extensions/curls) have no movement pattern — return empty array. Do not assign Pull to curls or Push to raises." ;
    ] ;

    # must have at least one muscle involvement
    sh:property [
        sh:path feg:hasInvolvement ;
        sh:minCount 1 ;
        sh:class feg:MuscleInvolvement ;
        sh:message "An exercise must have at least one muscle involvement." ;
    ] ;

    # must have at least one prime mover, unless it has a passive target (Mobility/SoftTissue)
    sh:sparql [
        sh:message "An exercise must have at least one PrimeMover involvement, or at least one PassiveTarget involvement for Mobility and SoftTissue exercises." ;
        rdfs:comment "An exercise must have at least one PrimeMover involvement, or at least one PassiveTarget involvement for Mobility and SoftTissue exercises." ;
        sh:select """
            PREFIX feg: <https://placeholder.url#>
            SELECT $this WHERE {
                FILTER NOT EXISTS {
                    $this feg:hasInvolvement ?inv .
                    ?inv feg:degree feg:PrimeMover .
                }
                FILTER NOT EXISTS {
                    $this feg:hasInvolvement ?inv .
                    ?inv feg:degree feg:PassiveTarget .
                }
            }
        """ ;
    ] ;

    # no muscle may appear more than once across involvements
    sh:sparql [
        sh:message "A muscle may not appear more than once across an exercise's muscle involvements." ;
        rdfs:comment "A muscle may not appear more than once across an exercise's muscle involvements." ;
        sh:select """
            PREFIX feg: <https://placeholder.url#>
            SELECT $this WHERE {
                $this feg:hasInvolvement ?inv1 ;
                      feg:hasInvolvement ?inv2 .
                ?inv1 feg:muscle ?muscle .
                ?inv2 feg:muscle ?muscle .
                FILTER (?inv1 != ?inv2)
            }
        """ ;
    ] ;

    # training modality if present must be a known individual
    sh:property [
        sh:path feg:trainingModality ;
        sh:class feg:TrainingModality ;
        sh:message "Training modality must be a known TrainingModality individual." ;
        rdfs:comment "Assign only when the modality is a defining characteristic of the exercise, not merely its typical training context. Plyometrics: explosive intent is the defining feature. Mobility: flexibility or range of motion is the defining feature. Cardio: cardiovascular adaptation is the defining feature. Omit for most resistance training exercises — a barbell squat, bench press, or deadlift has no defining modality." ;
    ] ;

    # equipment if present must be a known individual
    sh:property [
        sh:path feg:equipment ;
        sh:class feg:Equipment ;
        sh:message "Equipment must be a known Equipment individual." ;
    ] ;

    # legacySourceId if present must be a single string
    sh:property [
        sh:path feg:legacySourceId ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "legacySourceId must be a single string value." ;
    ] ;

    # isUnilateral if present must be a single boolean
    sh:property [
        sh:path feg:isUnilateral ;
        sh:maxCount 1 ;
        sh:datatype xsd:boolean ;
        sh:message "isUnilateral must be a single boolean value." ;
        rdfs:comment "Omit entirely for bilateral exercises. Set to true only when the exercise is inherently performed one limb at a time (e.g. single-leg squat, single-arm row). Absence is interpreted as bilateral by query consumers." ;
    ] ;

    # primary joint actions must be known JointAction individuals
    sh:property [
        sh:path feg:primaryJointAction ;
        sh:class feg:JointAction ;
        sh:message "Primary joint action must be a known JointAction individual." ;
        rdfs:comment "Assign the joint actions that directly produce the exercise's defining movement — the mechanical reason the exercise exists. For a deadlift: HipExtension, KneeExtension. For a curl: ElbowFlexion. Typically 1–3 per exercise. Leaf-level concepts only — do not assign joint grouping nodes (Shoulder, Hip, etc.). Anti-movement rule (applies to all three Anti* patterns): if the exercise is AntiExtension → SpinalStability; AntiRotation → SpinalStability; AntiLateralFlexion → SpinalStability. In all three cases the spine is isometrically resisting — not producing — movement. Do NOT assign SpinalExtension, SpinalRotation, or SpinalLateralFlexion to these exercises." ;
    ] ;

    # supporting joint actions must be known JointAction individuals
    sh:property [
        sh:path feg:supportingJointAction ;
        sh:class feg:JointAction ;
        sh:message "Supporting joint action must be a known JointAction individual." ;
        rdfs:comment "Assign joint actions that contribute meaningfully but are not the defining stimulus — only those relevant for substitution decisions, fatigue accumulation, or inter-muscular coordination. This is not a biomechanical inventory: omit incidental or purely stabilising actions. Leave empty if nothing qualifies. Typically 0–3 per exercise. Leaf-level concepts only. Setup-position rule: do not assign joint actions that describe the starting position of the exercise — only actions that occur during the movement itself. Examples: bent knees at the start of a glute bridge are setup, not KneeFlexion as a joint action; semi-locked knees during a good morning are setup, not a movement action. Ankle mechanics for sagittal plane lifts: for squats, deadlifts, and lunges the relevant ankle action is Dorsiflexion (the ankle dorsiflexes to allow depth). AnkleEversion and AnkleInversion are movement faults, not defining supporting actions in these exercises." ;
    ] ;

    # isCompound if present must be a single boolean
    sh:property [
        sh:path feg:isCompound ;
        sh:maxCount 1 ;
        sh:datatype xsd:boolean ;
        sh:message "isCompound must be a single boolean value." ;
        rdfs:comment "Set to true when the exercise involves meaningful force production across multiple joints (e.g. squat, deadlift, bench press, row). Omit or set to false for single-joint isolation exercises (e.g. bicep curl, leg extension, lateral raise). When in doubt, count primary joint actions: two or more distinct joints contributing to force production indicates compound." ;
    ] ;

    # no exercise may list both a muscle and one of its SKOS ancestors — double-counting
    sh:sparql [
        sh:message "An exercise may not assign both a muscle and one of its ancestors — this double-counts the same muscle mass. Use the most specific term only." ;
        rdfs:comment "An exercise may not assign both a muscle and one of its ancestors — this double-counts the same muscle mass. Use the most specific term only." ;
        sh:select """
            PREFIX feg: <https://placeholder.url#>
            PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
            SELECT $this WHERE {
                $this feg:hasInvolvement ?inv1 ;
                      feg:hasInvolvement ?inv2 .
                ?inv1 feg:muscle ?child .
                ?inv2 feg:muscle ?ancestor .
                FILTER (?inv1 != ?inv2)
                ?child skos:broader+ ?ancestor .
            }
        """ ;
    ] ;
.

###################
# MuscleInvolvementShape
###################

feg:MuscleInvolvementShape
    a sh:NodeShape ;
    sh:targetClass feg:MuscleInvolvement ;
    rdfs:label "Muscle Involvement Shape" ;
    rdfs:comment "Validates that every MuscleInvolvement instance is complete and well-formed." ;

    # must have exactly one muscle
    sh:property [
        sh:path feg:muscle ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class feg:Muscle ;
        sh:message "A muscle involvement must reference exactly one known Muscle individual." ;
        rdfs:comment "Prefer the most specific term available: MuscleHead > MuscleGroup > MuscleRegion. Use a region term only if no group applies; use a group term only if no head applies. Exception: groups marked useGroupLevel=true are the correct term — do not descend to their heads. Exception: Core (a MuscleGroup under Abdominals) is a convenience term permitted on compound movements where abdominal bracing is incidental — see Core usage constraint below. Critical: joint action concept names (e.g. ScapularUpwardRotation, HipFlexion, ElbowFlexion, ScapularRetraction) are NOT muscle names. Never use a joint action concept as a muscle value. All valid muscle names are listed in the muscle hierarchy above. TricepsBrachii (group) must not be used. Always decompose into TricepsLongHead, TricepsLateralHead, and TricepsMedialHead — including Stabilizer and Synergist roles. TricepsLongHead is meaningfully distinct as it crosses the shoulder joint. On Mobility exercises and passive stretches, minimize Stabilizers. Include a Stabilizer only when there is a clear active stabilization demand. Do not routinely add Core or RotatorCuff to all exercises." ;
    ] ;

    # must have exactly one degree
    sh:property [
        sh:path feg:degree ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class feg:InvolvementDegree ;
        sh:message "A muscle involvement must have exactly one degree, and it must be a known InvolvementDegree individual." ;
    ] ;

    # degree must be one of the three allowed values
    sh:property [
        sh:path feg:degree ;
        sh:in ( feg:PrimeMover feg:Synergist feg:Stabilizer feg:PassiveTarget ) ;
        sh:message "Degree must be one of: PrimeMover, Synergist, Stabilizer, PassiveTarget." ;
    ] ;

    # muscle must not be a JointAction individual — feg:Muscle owl:disjointWith feg:JointAction
    sh:sparql [
        sh:message "A muscle involvement's feg:muscle value is a JointAction individual, not a Muscle. Joint action concept names (e.g. ScapularUpwardRotation, ScapularRetraction, HipFlexion) describe movement at a joint — they are not muscles. Check the muscle hierarchy for the correct muscle name." ;
        rdfs:comment "A muscle involvement's feg:muscle value must not be a feg:JointAction individual. Joint action concept names (e.g. ScapularUpwardRotation, ScapularRetraction, HipFlexion, ElbowFlexion) describe movement at a joint — they are NOT muscles. If you find yourself writing a joint action name as a muscle, check the muscle hierarchy listed above for the correct anatomical term." ;
        sh:select """
            PREFIX feg: <https://placeholder.url#>
            PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
            SELECT $this WHERE {
                $this feg:muscle ?muscle .
                ?muscle rdf:type feg:JointAction .
            }
        """ ;
    ] ;

    # must be referenced by at least one exercise - catches orphaned nodes
    sh:sparql [
        sh:message "A MuscleInvolvement must be referenced by at least one Exercise via hasInvolvement." ;
        sh:select """
            PREFIX feg: <https://placeholder.url#>
            SELECT $this WHERE {
                FILTER NOT EXISTS {
                    ?exercise feg:hasInvolvement $this .
                }
            }
        """ ;
    ] ;

    # Core must always be assigned as Stabilizer
    sh:sparql [
        sh:message "Core must be assigned as Stabilizer only. For dedicated core exercises where the abdominals are the primary target, use specific muscles (RectusAbdominis, Obliques, TransverseAbdominis) instead." ;
        rdfs:comment "Core must be assigned as Stabilizer only. For dedicated core exercises where the abdominals are the primary target, use specific muscles (RectusAbdominis, Obliques, TransverseAbdominis) instead." ;
        sh:select """
            PREFIX feg: <https://placeholder.url#>
            SELECT $this WHERE {
                $this feg:muscle feg:Core .
                $this feg:degree ?degree .
                FILTER (?degree != feg:Stabilizer)
            }
        """ ;
    ] ;

    # must not reference a head whose parent group has useGroupLevel=true
    sh:sparql [
        sh:message "This involvement references a muscle head whose parent group has useGroupLevel=true. Use the group-level term instead." ;
        rdfs:comment "Do not use a MuscleHead when its parent MuscleGroup has useGroupLevel=true. The group is the correct granularity for these muscles in exercise programming." ;
        sh:select """
            PREFIX feg: <https://placeholder.url#>
            PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
            SELECT $this WHERE {
                $this feg:muscle ?head .
                ?head skos:broader ?group .
                ?group feg:useGroupLevel true .
            }
        """ ;
    ] ;
.

###################
# JointActionShape
###################

feg:JointActionShape
    a sh:NodeShape ;
    sh:targetClass feg:JointAction ;
    rdfs:label "Joint Action Shape" ;
    rdfs:comment "Validates joint action vocabulary concepts." ;

    # must have exactly one rdfs:label
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "A joint action must have exactly one rdfs:label." ;
    ] ;

    # must belong to the JointActionScheme
    sh:property [
        sh:path skos:inScheme ;
        sh:hasValue feg:JointActionScheme ;
        sh:minCount 1 ;
        sh:message "A joint action must be in feg:JointActionScheme." ;
    ] ;

    # must have a broader joint grouping node
    sh:property [
        sh:path skos:broader ;
        sh:minCount 1 ;
        sh:message "A joint action must have a skos:broader joint grouping node (e.g. feg:Shoulder, feg:Hip)." ;
    ] ;
.

###################
# MuscleShape
###################

feg:MuscleShape
    a sh:NodeShape ;
    sh:targetClass feg:MuscleGroup ;
    rdfs:label "Muscle Group Shape" ;
    rdfs:comment "Validates muscle group vocabulary concepts." ;

    # useGroupLevel if present must be a single boolean
    sh:property [
        sh:path feg:useGroupLevel ;
        sh:maxCount 1 ;
        sh:datatype xsd:boolean ;
        sh:message "useGroupLevel must be a single boolean value." ;
    ] ;
.
