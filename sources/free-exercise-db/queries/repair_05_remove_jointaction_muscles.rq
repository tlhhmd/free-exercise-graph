# repair_05_remove_jointaction_muscles.rq
#
# Remove MuscleInvolvement nodes where feg:muscle points to a feg:JointAction
# individual. feg:Muscle and feg:JointAction are declared owl:disjointWith —
# a JointAction concept is never a valid muscle value.
#
# This failure mode arises when the LLM copies a joint action concept name
# (e.g. ScapularUpwardRotation) into the muscle_involvements field. The SHACL
# constraint on MuscleInvolvementShape catches it at validation time; this query
# removes it automatically at ingest time.

PREFIX feg: <https://placeholder.url#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

DELETE {
    ?exercise feg:hasInvolvement ?inv .
    ?inv ?p ?o .
}
WHERE {
    ?exercise feg:hasInvolvement ?inv .
    ?inv feg:muscle ?muscle .
    ?muscle rdf:type feg:JointAction .
    ?inv ?p ?o .
}
