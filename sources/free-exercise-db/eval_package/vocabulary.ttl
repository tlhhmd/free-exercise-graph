@prefix feg: <https://placeholder.url#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

feg: a owl:Ontology ;
    rdfs:label "Free Exercise Graph Ontology" ;
    rdfs:comment "An ontology for exercise science, extending free-exercise-db with semantic properties." ;
    owl:versionInfo "0.2.1" .

feg:AdductorBrevis a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Adductor Brevis" ;
    skos:broader feg:Adductors ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Adductor Brevis" .

feg:AdductorLongus a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Adductor Longus" ;
    skos:broader feg:Adductors ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Adductor Longus" .

feg:AdductorMagnus a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Adductor Magnus" ;
    skos:broader feg:Adductors ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Adductor Magnus" .

feg:AnteriorDeltoid a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Anterior Deltoid" ;
    skos:altLabel "Front Delt" ;
    skos:broader feg:Deltoid ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Anterior Deltoid" .

feg:AnteriorScalene a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Anterior Scalene" ;
    skos:broader feg:Scalenes ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Anterior Scalene" .

feg:BicepsFemoris a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Biceps Femoris" ;
    skos:broader feg:Hamstrings ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Biceps Femoris" .

feg:BicepsLongHead a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Biceps Long Head" ;
    skos:broader feg:BicepsBrachii ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Biceps Long Head" .

feg:BicepsShortHead a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Biceps Short Head" ;
    skos:broader feg:BicepsBrachii ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Biceps Short Head" .

feg:Brachialis a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Brachialis" ;
    skos:broader feg:Biceps ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Brachialis" .

feg:Brachioradialis a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Brachioradialis" ;
    skos:broader feg:Forearms ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Brachioradialis" ;
    skos:related feg:Biceps .

feg:Cardio a owl:NamedIndividual,
        feg:TrainingModality ;
    rdfs:label "Cardio" ;
    rdfs:comment "Training principally focused on improving cardiovascular endurance and aerobic capacity." .

feg:Carry a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:comment "Movements in which load is held and transported through space, demanding full-body stability and grip strength." ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Carry" .

feg:ClavicularHead a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Clavicular Head" ;
    skos:altLabel "Upper Chest" ;
    skos:broader feg:PectoralisMajor ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Clavicular Head" .

feg:Core a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Core" ;
    skos:altLabel "Anterior Core" ;
    skos:broader feg:Abdominals ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Core" ;
    skos:scopeNote "Convenience term for the anterior trunk as a functional unit. Use on compound movements where abdominal bracing is incidental. Use specific muscles (RectusAbdominis, Obliques, TransverseAbdominis) for dedicated core exercises where the core is the primary target." .

feg:ExtensorCarpiRadialis a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Extensor Carpi Radialis" ;
    skos:broader feg:WristExtensors ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Extensor Carpi Radialis" .

feg:ExtensorCarpiUlnaris a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Extensor Carpi Ulnaris" ;
    skos:broader feg:WristExtensors ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Extensor Carpi Ulnaris" .

feg:ExternalOblique a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "External Oblique" ;
    skos:broader feg:Obliques ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "External Oblique" .

feg:FlexorCarpiRadialis a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Flexor Carpi Radialis" ;
    skos:broader feg:WristFlexors ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Flexor Carpi Radialis" .

feg:FlexorCarpiUlnaris a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Flexor Carpi Ulnaris" ;
    skos:broader feg:WristFlexors ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Flexor Carpi Ulnaris" .

feg:GluteusMaximus a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Gluteus Maximus" ;
    skos:broader feg:Glutes ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Gluteus Maximus" .

feg:GluteusMedius a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Gluteus Medius" ;
    skos:broader feg:Glutes ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Gluteus Medius" ;
    skos:related feg:Abductors .

feg:GluteusMinimus a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Gluteus Minimus" ;
    skos:broader feg:Glutes ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Gluteus Minimus" ;
    skos:related feg:Abductors .

feg:Gracilis a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Gracilis" ;
    skos:broader feg:Adductors ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Gracilis" .

feg:HipHinge a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:comment "Movements in which the hips are the primary joint driving the exercise, involving significant posterior chain recruitment." ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Hip Hinge" .

feg:HorizontalPull a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:comment "Movements in which force is produced by pulling horizontally toward the body, principally targeting the mid-back, rear deltoid, and biceps." ;
    skos:broader feg:Pull ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Horizontal Pull" .

feg:HorizontalPush a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:comment "Movements in which force is produced by pushing horizontally away from the body, principally targeting the chest, anterior deltoid, and triceps." ;
    skos:broader feg:Push ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Horizontal Push" .

feg:Hypertrophy a owl:NamedIndividual,
        feg:TrainingModality ;
    rdfs:label "Hypertrophy" ;
    rdfs:comment "Training principally focused on increasing muscle size through moderate loads and moderate to high repetitions." .

feg:Iliocostalis a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Iliocostalis" ;
    skos:broader feg:ErectorSpinae ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Iliocostalis" .

feg:Iliopsoas a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Iliopsoas" ;
    skos:altLabel "Psoas Major" ;
    skos:broader feg:Psoas ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Iliopsoas" .

feg:Infraspinatus a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Infraspinatus" ;
    skos:broader feg:RotatorCuff ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Infraspinatus" .

feg:InternalOblique a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Internal Oblique" ;
    skos:broader feg:Obliques ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Internal Oblique" .

feg:InvolvementDegreeVocabulary a owl:Ontology ;
    owl:versionInfo "0.1.0" .

feg:LateralDeltoid a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Lateral Deltoid" ;
    skos:altLabel "Side Delt" ;
    skos:broader feg:Deltoid ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Lateral Deltoid" .

feg:LateralGastrocnemius a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Lateral Gastrocnemius" ;
    skos:broader feg:Gastrocnemius ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Lateral Gastrocnemius" .

feg:LatissimusDorsi a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Latissimus Dorsi" ;
    skos:altLabel "Lats" ;
    skos:broader feg:Lats ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Latissimus Dorsi" .

feg:Locomotion a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:comment "Movements involving whole-body travel through space, including running, jumping, and crawling patterns." ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Locomotion" .

feg:Longissimus a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Longissimus" ;
    skos:broader feg:ErectorSpinae ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Longissimus" .

feg:LowerTrapezius a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Lower Trapezius" ;
    skos:altLabel "Lower Traps" ;
    skos:broader feg:Trapezius ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Lower Trapezius" .

feg:Lunge a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:comment "A knee dominant movement in which one foot travels to create a staggered stance, introducing a dynamic balance demand absent in the split squat." ;
    skos:broader feg:KneeDominant ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Lunge" .

feg:MedialGastrocnemius a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Medial Gastrocnemius" ;
    skos:broader feg:Gastrocnemius ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Medial Gastrocnemius" .

feg:MiddleScalene a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Middle Scalene" ;
    skos:broader feg:Scalenes ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Middle Scalene" .

feg:MiddleTrapezius a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Middle Trapezius" ;
    skos:altLabel "Mid Traps" ;
    skos:broader feg:Trapezius ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Middle Trapezius" ;
    skos:related feg:MiddleBack .

feg:Mobility a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern,
        feg:TrainingModality ;
    rdfs:label "Mobility" ;
    rdfs:comment "Static and dynamic stretching, flexibility work, and range of motion exercises. Distinct from SoftTissue, which covers foam rolling and myofascial release.",
        "Training principally focused on improving range of motion and movement quality at a joint or across multiple joints." ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Mobility" .

feg:PectoralisMinor a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Pectoralis Minor" ;
    skos:altLabel "Pec Minor" ;
    skos:broader feg:Chest ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Pectoralis Minor" .

feg:Plyometrics a owl:NamedIndividual,
        feg:TrainingModality ;
    rdfs:label "Plyometrics" ;
    rdfs:comment "Training principally focused on developing explosive power through rapid stretch-shortening cycles." .

feg:PosteriorDeltoid a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Posterior Deltoid" ;
    skos:altLabel "Rear Delt" ;
    skos:broader feg:Deltoid ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Posterior Deltoid" .

feg:PosteriorScalene a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Posterior Scalene" ;
    skos:broader feg:Scalenes ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Posterior Scalene" .

feg:PrimeMover a owl:NamedIndividual,
        feg:InvolvementDegree ;
    rdfs:label "Prime Mover" ;
    rdfs:comment "The muscle or muscles primarily responsible for producing the movement in an exercise. The prime mover is the intended target of the exercise." .

feg:QuadratusLumborum a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Quadratus Lumborum" ;
    skos:altLabel "QL" ;
    skos:broader feg:LowerBack ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Quadratus Lumborum" .

feg:RectusAbdominis a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Rectus Abdominis" ;
    skos:altLabel "Abs" ;
    skos:broader feg:Abdominals ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Rectus Abdominis" .

feg:RectusFemoris a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Rectus Femoris" ;
    skos:broader feg:Quadriceps ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Rectus Femoris" .

feg:RhomboidMajor a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Rhomboid Major" ;
    skos:broader feg:Rhomboids ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Rhomboid Major" .

feg:RhomboidMinor a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Rhomboid Minor" ;
    skos:broader feg:Rhomboids ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Rhomboid Minor" .

feg:Rotation a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:comment "Movements involving rotation or anti-rotation of the trunk, principally targeting the obliques and deep core musculature." ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Rotation" .

feg:Semimembranosus a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Semimembranosus" ;
    skos:broader feg:Hamstrings ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Semimembranosus" .

feg:Semitendinosus a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Semitendinosus" ;
    skos:broader feg:Hamstrings ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Semitendinosus" .

feg:SerratusAnterior a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Serratus Anterior" ;
    skos:broader feg:Chest ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Serratus Anterior" .

feg:SoftTissue a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:comment "Foam rolling, myofascial release, and similar soft tissue techniques. Not a movement in the traditional sense but a distinct exercise category in the source dataset." ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Soft Tissue" .

feg:Soleus a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Soleus" ;
    skos:broader feg:Calves ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Soleus" .

feg:Spinalis a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Spinalis" ;
    skos:broader feg:ErectorSpinae ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Spinalis" .

feg:SplitSquat a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:comment "A knee dominant movement performed with a staggered stance, both feet fixed, placing greater demand on the forward leg." ;
    skos:broader feg:KneeDominant ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Split Squat" .

feg:Squat a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:comment "A bilateral knee dominant movement in which both feet remain fixed and the hips descend toward the ground." ;
    skos:broader feg:KneeDominant ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Squat" .

feg:Stabilizer a owl:NamedIndividual,
        feg:InvolvementDegree ;
    rdfs:label "Stabilizer" ;
    rdfs:comment "A muscle that contracts to stabilize a joint during the exercise without contributing directly to the movement. Stabilizers are active but not trained in a meaningful hypertrophic or strength sense by the exercise." .

feg:SternalHead a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Sternal Head" ;
    skos:altLabel "Lower Chest" ;
    skos:broader feg:PectoralisMajor ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Sternal Head" .

feg:Sternocleidomastoid a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Sternocleidomastoid" ;
    skos:altLabel "SCM" ;
    skos:broader feg:Neck ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Sternocleidomastoid" .

feg:Strength a owl:NamedIndividual,
        feg:TrainingModality ;
    rdfs:label "Strength" ;
    rdfs:comment "Training principally focused on developing maximal force production, typically performed at high loads and low repetitions." .

feg:Subscapularis a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Subscapularis" ;
    skos:broader feg:RotatorCuff ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Subscapularis" .

feg:Supraspinatus a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Supraspinatus" ;
    skos:broader feg:RotatorCuff ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Supraspinatus" .

feg:Synergist a owl:NamedIndividual,
        feg:InvolvementDegree ;
    rdfs:label "Synergist" ;
    rdfs:comment "A muscle that assists the prime mover in producing the movement. The synergist contributes meaningfully to the exercise but is not the primary target." .

feg:TensorFasciaeLatae a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Tensor Fasciae Latae" ;
    skos:altLabel "TFL" ;
    skos:broader feg:Abductors ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Tensor Fasciae Latae" .

feg:TeresMinor a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Teres Minor" ;
    skos:broader feg:RotatorCuff ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Teres Minor" .

feg:TibialisAnterior a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Tibialis Anterior" ;
    skos:altLabel "Tibialis" ;
    skos:broader feg:LowerLeg ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Tibialis Anterior" .

feg:TrainingModalityVocabulary a owl:Ontology ;
    owl:versionInfo "0.1.0" .

feg:TransverseAbdominis a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Transverse Abdominis" ;
    skos:altLabel "TVA" ;
    skos:broader feg:Abdominals ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Transverse Abdominis" .

feg:TricepsLateralHead a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Triceps Lateral Head" ;
    skos:broader feg:TricepsBrachii ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Triceps Lateral Head" .

feg:TricepsLongHead a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Triceps Long Head" ;
    skos:broader feg:TricepsBrachii ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Triceps Long Head" .

feg:TricepsMedialHead a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Triceps Medial Head" ;
    skos:broader feg:TricepsBrachii ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Triceps Medial Head" .

feg:TrunkStability a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:comment "Movements principally targeting trunk stability and strength through flexion, extension, or isometric demand. Distinct from Rotation, which covers rotational and anti-rotational patterns." ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Trunk Stability" .

feg:UpperTrapezius a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Upper Trapezius" ;
    skos:altLabel "Upper Traps" ;
    skos:broader feg:Trapezius ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Upper Trapezius" .

feg:VastusIntermedius a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Vastus Intermedius" ;
    skos:broader feg:Quadriceps ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Vastus Intermedius" .

feg:VastusLateralis a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Vastus Lateralis" ;
    skos:broader feg:Quadriceps ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Vastus Lateralis" .

feg:VastusMedialis a skos:Concept,
        feg:MuscleHead ;
    rdfs:label "Vastus Medialis" ;
    skos:altLabel "VMO" ;
    skos:broader feg:Quadriceps ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Vastus Medialis" .

feg:VerticalPull a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:comment "Movements in which force is produced by pulling vertically toward the body, principally targeting the lats and biceps." ;
    skos:broader feg:Pull ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Vertical Pull" .

feg:VerticalPush a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:comment "Movements in which force is produced by pushing vertically away from the body, principally targeting the shoulders and triceps." ;
    skos:broader feg:Push ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Vertical Push" .

feg:degree a owl:ObjectProperty ;
    rdfs:label "degree" ;
    rdfs:comment "Relates a muscle involvement instance to the degree to which the muscle is recruited." ;
    rdfs:domain feg:MuscleInvolvement ;
    rdfs:range feg:InvolvementDegree .

feg:equipment a owl:ObjectProperty ;
    rdfs:label "equipment" ;
    rdfs:comment "Relates an exercise to the equipment used to perform it." ;
    rdfs:domain feg:Exercise ;
    rdfs:range feg:Equipment .

feg:hasInvolvement a owl:ObjectProperty ;
    rdfs:label "has involvement" ;
    rdfs:comment "Relates an exercise to a muscle involvement instance describing a muscle recruited during its execution." ;
    rdfs:domain feg:Exercise ;
    rdfs:range feg:MuscleInvolvement .

feg:isUnilateral a owl:DatatypeProperty ;
    rdfs:label "is unilateral" ;
    rdfs:comment "True if the exercise is performed one limb at a time. When absent, bilateral execution is assumed." ;
    rdfs:domain feg:Exercise ;
    rdfs:range xsd:boolean .

feg:legacySourceId a owl:DatatypeProperty ;
    rdfs:label "legacy source ID" ;
    rdfs:comment "The original identifier for this exercise in the yuhonas/free-exercise-db dataset. Preserved for provenance and upstream traceability." ;
    rdfs:domain feg:Exercise ;
    rdfs:range xsd:string .

feg:movementPattern a owl:ObjectProperty ;
    rdfs:label "movement pattern" ;
    rdfs:comment "Relates an exercise to its fundamental movement pattern." ;
    rdfs:domain feg:Exercise ;
    rdfs:range feg:MovementPattern .

feg:muscle a owl:ObjectProperty ;
    rdfs:label "muscle" ;
    rdfs:comment "Relates a muscle involvement instance to the muscle being recruited." ;
    rdfs:domain feg:MuscleInvolvement ;
    rdfs:range feg:Muscle .

feg:trainingModality a owl:ObjectProperty ;
    rdfs:label "training modality" ;
    rdfs:comment "Relates an exercise to the physiological adaptation it primarily targets." ;
    rdfs:domain feg:Exercise ;
    rdfs:range feg:TrainingModality .

feg:useGroupLevel a owl:DatatypeProperty ;
    rdfs:label "use group level" ;
    rdfs:comment "Indicates that this MuscleGroup functions as a single training unit — its constituent muscles cannot be selectively recruited or meaningfully targeted independently through exercise selection. The group term is the appropriate level of specificity; the individual head-level concepts exist for anatomical completeness but do not represent distinct training outcomes." ;
    rdfs:domain feg:MuscleGroup ;
    rdfs:range xsd:boolean ;
    skos:editorialNote "Used by the classification pipeline to enforce group-level usage. Groups with this flag are surfaced in the prompt as explicit exceptions to the head-preference rule, and a SHACL constraint rejects any classification that references one of their child heads." .

feg:Equipment a owl:Class ;
    rdfs:label "Equipment" ;
    rdfs:comment "A physical tool or apparatus used to perform an exercise." .

feg:Lats a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Lats" ;
    skos:altLabel "Latissimus Dorsi" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Lats" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Psoas a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Psoas" ;
    skos:altLabel "Hip Flexors" ;
    skos:broader feg:LowerBack ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Psoas" ;
    skos:related feg:Quadriceps .

feg:Traps a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Traps" ;
    skos:altLabel "Trapezius" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Traps" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Triceps a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Triceps" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Triceps" ;
    skos:topConceptOf feg:MuscleScheme .

feg:BicepsBrachii a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Biceps Brachii" ;
    skos:broader feg:Biceps ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Biceps Brachii" .

feg:Calves a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Calves" ;
    skos:broader feg:LowerLeg ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Calves" .

feg:Gastrocnemius a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Gastrocnemius" ;
    skos:broader feg:Calves ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Gastrocnemius" ;
    feg:useGroupLevel true .

feg:LowerLeg a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Lower Leg" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Lower Leg" ;
    skos:topConceptOf feg:MuscleScheme .

feg:MiddleBack a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Middle Back" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Middle Back" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Neck a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Neck" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Neck" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Obliques a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Obliques" ;
    skos:broader feg:Abdominals ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Obliques" ;
    feg:useGroupLevel true .

feg:PectoralisMajor a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Pectoralis Major" ;
    skos:altLabel "Pec Major" ;
    skos:broader feg:Chest ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Pectoralis Major" .

feg:Pull a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:comment "Movements in which force is produced by pulling load toward the body." ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Pull" .

feg:Push a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:comment "Movements in which force is produced by pushing load away from the body." ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Push" .

feg:Rhomboids a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Rhomboids" ;
    skos:broader feg:MiddleBack ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Rhomboids" ;
    feg:useGroupLevel true .

feg:Shoulders a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Shoulders" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Shoulders" ;
    skos:topConceptOf feg:MuscleScheme .

feg:WristExtensors a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Wrist Extensors" ;
    skos:broader feg:Forearms ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Wrist Extensors" ;
    feg:useGroupLevel true .

feg:WristFlexors a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Wrist Flexors" ;
    skos:broader feg:Forearms ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Wrist Flexors" ;
    feg:useGroupLevel true .

feg:Abductors a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Abductors" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Abductors" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Biceps a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Biceps" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Biceps" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Chest a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Chest" ;
    skos:altLabel "Pectorals" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Chest" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Deltoid a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Deltoid" ;
    skos:broader feg:Shoulders ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Deltoid" .

feg:ErectorSpinae a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Erector Spinae" ;
    skos:broader feg:LowerBack ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Erector Spinae" ;
    feg:useGroupLevel true .

feg:Forearms a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Forearms" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Forearms" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Glutes a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Glutes" ;
    skos:altLabel "Gluteal Muscles" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Glutes" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Hamstrings a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Hamstrings" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Hamstrings" ;
    skos:topConceptOf feg:MuscleScheme .

feg:KneeDominant a owl:NamedIndividual,
        skos:Concept,
        feg:MovementPattern ;
    rdfs:comment "Movements in which the knee is the primary joint driving the exercise, involving significant quadriceps recruitment." ;
    skos:inScheme feg:MovementPatternScheme ;
    skos:prefLabel "Knee Dominant" .

feg:LowerBack a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Lower Back" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Lower Back" ;
    skos:topConceptOf feg:MuscleScheme .

feg:MuscleInvolvement a owl:Class ;
    rdfs:label "Muscle Involvement" ;
    rdfs:comment "A relationship between a specific exercise and a specific muscle, capturing the degree to which that muscle is recruited during the exercise. A single exercise may have multiple muscle involvements, one per involved muscle." .

feg:Scalenes a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Scalenes" ;
    skos:broader feg:Neck ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Scalenes" ;
    feg:useGroupLevel true .

feg:Trapezius a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Trapezius" ;
    skos:broader feg:Traps ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Trapezius" .

feg:TricepsBrachii a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Triceps Brachii" ;
    skos:broader feg:Triceps ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Triceps Brachii" .

feg:Abdominals a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Abdominals" ;
    skos:altLabel "Abs" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Abdominals" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Adductors a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Adductors" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Adductors" ;
    skos:topConceptOf feg:MuscleScheme .

feg:InvolvementDegree a owl:Class ;
    rdfs:label "Involvement Degree" ;
    rdfs:comment "A classification describing the role a muscle plays in an exercise." .

feg:Muscle a owl:Class ;
    rdfs:label "Muscle" ;
    rdfs:comment "Superclass for all muscle vocabulary terms. Covers regions, groups, and heads. The feg:muscle property on MuscleInvolvement may point to any level of the hierarchy." .

feg:RotatorCuff a skos:Concept,
        feg:MuscleGroup ;
    rdfs:label "Rotator Cuff" ;
    skos:broader feg:Shoulders ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Rotator Cuff" ;
    feg:useGroupLevel true .

feg:Quadriceps a skos:Concept,
        feg:MuscleRegion ;
    rdfs:label "Quadriceps" ;
    skos:altLabel "Quads" ;
    skos:inScheme feg:MuscleScheme ;
    skos:prefLabel "Quadriceps" ;
    skos:topConceptOf feg:MuscleScheme .

feg:Exercise a owl:Class ;
    rdfs:label "Exercise" ;
    rdfs:comment "A bodily activity that enhances or maintains physical fitness and overall health and wellness." .

feg:TrainingModality a owl:Class ;
    rdfs:label "Training Modality" ;
    rdfs:comment "A category describing the physiological adaptation targeted by an exercise or program. Examples include strength, hypertrophy, cardio, and mobility." .

feg:MovementPatternScheme a skos:ConceptScheme ;
    rdfs:label "Movement Pattern Scheme" ;
    rdfs:comment "A controlled vocabulary of fundamental human movement patterns used to classify exercises." ;
    owl:versionInfo "0.4.0" .

feg:MovementPattern a owl:Class ;
    rdfs:label "Movement Pattern" ;
    rdfs:comment "A fundamental category of human movement that describes the mechanical structure of an exercise. Exercises sharing a movement pattern make similar demands on the musculoskeletal system and may serve as substitutes for one another." .

feg:MuscleRegion a owl:Class ;
    rdfs:label "Muscle Region" ;
    rdfs:comment "A colloquial regional grouping of muscles used in exercise science (e.g. Shoulders, Lats, Quads). Corresponds to the coarse terms used in the source dataset." ;
    rdfs:subClassOf feg:Muscle .

feg:MuscleGroup a owl:Class ;
    rdfs:label "Muscle Group" ;
    rdfs:comment "An individual muscle or functional muscle group (e.g. Deltoid, Triceps Brachii, Erector Spinae)." ;
    rdfs:subClassOf feg:Muscle .

feg:MuscleHead a owl:Class ;
    rdfs:label "Muscle Head" ;
    rdfs:comment "A distinct head, portion, or fiber region of a muscle (e.g. Anterior Deltoid, Biceps Long Head). The LLM enrichment pipeline classifies at this level where applicable." ;
    rdfs:subClassOf feg:Muscle .

feg:MuscleScheme a skos:ConceptScheme ;
    rdfs:label "Muscle Vocabulary" ;
    rdfs:comment "SKOS concept scheme organizing muscles by region." ;
    owl:versionInfo "0.8.0" ;
    skos:prefLabel "Muscle Vocabulary" .

